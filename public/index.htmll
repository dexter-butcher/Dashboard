<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Sentrax — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0101;--bg2:#110202;--bg3:#1a0303;--bg4:#200404;
  --border:#2d0808;--border2:#3d1010;
  --red:#c0392b;--red2:#e74c3c;--red3:#ff6b6b;
  --red-dim:rgba(192,57,43,.12);--red-glow:rgba(231,76,60,.25);
  --green:#27ae60;--gold:#d4a843;
  --tx:#f0e8e8;--tx2:#a08080;--tx3:#5a3535;
}
html{scroll-behavior:smooth}
body{font-family:'Rajdhani',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 20% -10%,rgba(192,57,43,.08),transparent),radial-gradient(ellipse 60% 40% at 80% 110%,rgba(192,57,43,.05),transparent);pointer-events:none;z-index:0}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--red);border-radius:2px}
#landing{display:flex;flex-direction:column;min-height:100vh;position:relative;z-index:1}
.lnav{display:flex;align-items:center;justify-content:space-between;padding:16px 32px;border-bottom:1px solid var(--border);background:rgba(10,1,1,.9);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100}
.lnav-logo{font-family:'Bebas Neue',cursive;font-size:28px;letter-spacing:4px;color:var(--red2);text-shadow:0 0 20px var(--red-glow)}
.lnav-logo span{color:var(--tx);opacity:.4;font-size:13px;letter-spacing:2px;margin-left:4px;font-family:'JetBrains Mono',monospace}
.lnav-links{display:flex;align-items:center;gap:24px}
.lnav-link{color:var(--tx2);font-size:12px;font-weight:600;text-decoration:none;letter-spacing:1px;text-transform:uppercase;transition:color .2s}.lnav-link:hover{color:var(--tx)}
.lnav-btn{background:var(--red);color:#fff;padding:9px 22px;border-radius:3px;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:all .2s;border:1px solid var(--red2);font-family:'Rajdhani',sans-serif}.lnav-btn:hover{background:var(--red2);box-shadow:0 0 20px var(--red-glow)}
.hero{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 24px 50px;position:relative;overflow:hidden}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(192,57,43,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(192,57,43,.04) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black,transparent)}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--red-dim);border:1px solid var(--border2);border-radius:2px;padding:6px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--red3);letter-spacing:2px;text-transform:uppercase;margin-bottom:28px;position:relative;z-index:1}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--red2);border-radius:50%;animation:blink 1.5s infinite}
@keyframes blink{0%,100%{opacity:1;box-shadow:0 0 6px var(--red2)}50%{opacity:.3;box-shadow:none}}
.hero-title{font-family:'Bebas Neue',cursive;font-size:clamp(60px,12vw,120px);line-height:.9;letter-spacing:6px;color:var(--tx);position:relative;z-index:1;margin-bottom:8px}
.hero-title .accent{color:var(--red2);text-shadow:0 0 40px var(--red-glow),0 0 80px rgba(192,57,43,.2)}
.hero-tm{font-family:'JetBrains Mono',monospace;font-size:18px;color:var(--tx3);vertical-align:super}
.hero-sub{color:var(--tx2);font-size:16px;font-weight:500;letter-spacing:.5px;max-width:520px;line-height:1.7;margin-bottom:36px;position:relative;z-index:1}
.hero-sub strong{color:var(--red3)}
.btn-hero{display:inline-flex;align-items:center;gap:10px;background:var(--red);color:#fff;padding:14px 32px;border-radius:3px;font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:all .25s;border:1px solid var(--red2);position:relative;z-index:1}
.btn-hero:hover{background:var(--red2);transform:translateY(-2px);box-shadow:0 8px 30px var(--red-glow)}
.hero-stats{display:flex;justify-content:center;flex-wrap:wrap;gap:0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-top:60px;position:relative;z-index:1;width:100%;max-width:700px}
.hstat{flex:1;min-width:120px;padding:24px 20px;text-align:center;border-right:1px solid var(--border);position:relative}.hstat:last-child{border-right:none}
.hstat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--red);opacity:0;transition:.3s}.hstat:hover::before{opacity:1}
.hstat-val{font-family:'Bebas Neue',cursive;font-size:38px;letter-spacing:2px;color:var(--red2);line-height:1}
.hstat-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx3);letter-spacing:2px;text-transform:uppercase;margin-top:4px}
/* Landing info sections */
.land-section{padding:70px 32px;max-width:1000px;margin:0 auto;position:relative;z-index:1}
.section-tag{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--red2);letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:10px}.section-tag::before{content:'//';opacity:.4}
.section-title{font-family:'Bebas Neue',cursive;font-size:clamp(30px,5vw,52px);letter-spacing:3px;margin-bottom:6px}
.section-sub{color:var(--tx2);font-size:13px;font-weight:500;letter-spacing:.5px;margin-bottom:40px}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1px;background:var(--border)}
.fc{background:var(--bg2);padding:28px;transition:all .2s;position:relative;overflow:hidden}.fc::after{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--red);transform:scaleY(0);transform-origin:bottom;transition:.25s}.fc:hover{background:var(--bg3)}.fc:hover::after{transform:scaleY(1)}
.fc-ico{font-size:24px;margin-bottom:14px;display:block}
.fc-name{font-family:'Bebas Neue',cursive;font-size:20px;letter-spacing:2px;color:var(--tx);margin-bottom:6px}
.fc-desc{font-size:12px;color:var(--tx2);line-height:1.7;font-weight:500}
/* How it works */
.steps{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1px;background:var(--border);margin-top:10px}
.step{background:var(--bg2);padding:28px;position:relative}
.step-num{font-family:'Bebas Neue',cursive;font-size:48px;color:var(--red);opacity:.3;line-height:1;margin-bottom:8px}
.step-title{font-family:'Bebas Neue',cursive;font-size:18px;letter-spacing:1px;margin-bottom:6px}
.step-desc{font-size:12px;color:var(--tx2);line-height:1.7}
.lfooter{padding:20px 32px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;position:relative;z-index:1}
.lfooter-logo{font-family:'Bebas Neue',cursive;font-size:18px;letter-spacing:3px;color:var(--tx3)}
.lfooter-copy{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx3);letter-spacing:1px}
/* ── APP ── */
#app{display:none;position:relative;z-index:1}
.sidebar{position:fixed;left:0;top:0;width:220px;height:100vh;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;transition:transform .25s}
.sb-top{padding:20px 18px 16px;border-bottom:1px solid var(--border)}
.sb-logo{font-family:'Bebas Neue',cursive;font-size:22px;letter-spacing:4px;color:var(--red2);text-shadow:0 0 15px var(--red-glow)}
.sb-logo-tm{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:1px;margin-top:2px}
.sb-server{padding:10px 14px;border-bottom:1px solid var(--border);cursor:pointer;display:flex;align-items:center;gap:10px;transition:.15s}.sb-server:hover{background:var(--bg3)}
.sb-server-icon{width:28px;height:28px;border-radius:3px;background:var(--bg4);flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',cursive;font-size:14px;color:var(--red2);border:1px solid var(--border2)}
.sb-server-icon img{width:100%;height:100%;object-fit:cover}
.sb-server-name{font-size:12px;font-weight:700;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;letter-spacing:.5px}
.sb-server-arr{color:var(--tx3);font-size:10px}
.snav{padding:8px;flex:1;overflow-y:auto}
.snav-label{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:2px;text-transform:uppercase;padding:12px 10px 4px}
.ni{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:2px;cursor:pointer;color:var(--tx2);font-size:13px;font-weight:600;letter-spacing:.5px;transition:all .15s;user-select:none;position:relative}
.ni:hover{background:var(--red-dim);color:var(--tx)}.ni.active{background:var(--red-dim);color:var(--red3)}.ni.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--red2)}
.ni-ico{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.sb-user{padding:10px 14px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px}
.sb-av{width:30px;height:30px;border-radius:3px;background:var(--bg4);flex-shrink:0;border:1px solid var(--border2)}
.sb-uname{font-size:12px;font-weight:700;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;letter-spacing:.5px}
.sb-out{background:none;border:none;color:var(--tx3);cursor:pointer;font-size:16px;padding:4px;transition:color .15s}.sb-out:hover{color:var(--red2)}
.sb-switch{background:none;border:none;color:var(--tx3);cursor:pointer;font-size:14px;padding:4px;transition:color .15s;font-family:'JetBrains Mono',monospace}.sb-switch:hover{color:var(--gold)}
.main{margin-left:220px;min-height:100vh}
.topbar{height:50px;background:rgba(10,1,1,.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 22px;gap:10px;position:sticky;top:0;z-index:50}
.tb-crumb{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tx3);letter-spacing:1px;flex:1}.tb-crumb span{color:var(--red2)}
.hamburger{display:none;background:none;border:none;color:var(--tx);cursor:pointer;padding:6px;flex-direction:column;gap:4px;margin-left:auto}.hamburger span{display:block;width:18px;height:2px;background:currentColor;border-radius:1px;transition:.2s}
.content{padding:24px;max-width:880px}
.page-section{display:none}
.page-header{margin-bottom:22px}
.page-title{font-family:'Bebas Neue',cursive;font-size:36px;letter-spacing:3px;color:var(--tx);line-height:1}
.page-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx3);letter-spacing:2px;margin-top:4px}
#guild-picker{padding:24px;display:none}
.guilds-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:2px;background:var(--border);margin-top:20px}
.gc{background:var(--bg2);padding:20px 16px;cursor:pointer;transition:all .2s;text-align:center;position:relative;overflow:hidden}.gc::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--red);transform:scaleX(0);transition:.2s}.gc:hover{background:var(--bg3)}.gc:hover::before{transform:scaleX(1)}
.gc-icon{width:52px;height:52px;border-radius:4px;margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',cursive;font-size:22px;color:var(--red2);background:var(--bg4);border:1px solid var(--border2);overflow:hidden}.gc-icon img{width:100%;height:100%;object-fit:cover}
.gc-name{font-size:12px;font-weight:700;letter-spacing:.5px}
.gp-empty{color:var(--tx3);font-size:12px;padding:30px 0;font-family:'JetBrains Mono',monospace;letter-spacing:1px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:2px;padding:20px;margin-bottom:14px;position:relative}.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--red),transparent)}
.card-title{font-family:'Bebas Neue',cursive;font-size:16px;letter-spacing:2px;color:var(--tx);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.fg{display:flex;flex-direction:column;gap:5px}
label{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:1.5px}
input,select,textarea{background:var(--bg3);border:1px solid var(--border2);border-radius:2px;color:var(--tx);font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:500;padding:9px 12px;outline:none;transition:border-color .15s;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--red)}
select option{background:var(--bg3)}
.tr{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)}.tr:last-child{border-bottom:none}
.tr-lbl{font-size:13px;font-weight:700;letter-spacing:.5px}.tr-sub{font-size:11px;color:var(--tx3);margin-top:2px;font-family:'JetBrains Mono',monospace;letter-spacing:.5px}
.tog{position:relative;width:38px;height:20px;flex-shrink:0}.tog input{opacity:0;width:0;height:0}
.tog-sl{position:absolute;cursor:pointer;inset:0;background:var(--bg4);border:1px solid var(--border2);border-radius:10px;transition:.2s}.tog-sl::before{content:'';position:absolute;width:12px;height:12px;left:3px;top:3px;background:var(--tx3);border-radius:50%;transition:.2s}
.tog input:checked+.tog-sl{background:var(--red-dim);border-color:var(--red)}.tog input:checked+.tog-sl::before{transform:translateX(18px);background:var(--red2)}
.btn-save{background:var(--red);color:#fff;border:none;border-radius:2px;padding:10px 22px;font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:all .2s;margin-top:14px}
.btn-save:hover{background:var(--red2);box-shadow:0 4px 16px var(--red-glow)}
/* Overview stats */
.sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:2px;background:var(--border);margin-bottom:16px}
.sc{background:var(--bg2);padding:16px;position:relative;overflow:hidden}.sc::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--red)}
.sc-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
.sc-val{font-family:'Bebas Neue',cursive;font-size:28px;letter-spacing:2px;color:var(--tx);line-height:1}
/* Feature status grid */
.feat-status{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:2px;background:var(--border);margin-bottom:16px}
.fs-item{background:var(--bg2);padding:14px;display:flex;align-items:center;justify-content:space-between}
.fs-name{font-size:12px;font-weight:700;letter-spacing:.5px}
.fs-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.fs-dot.on{background:var(--green);box-shadow:0 0 6px var(--green)}
.fs-dot.off{background:var(--tx3)}
/* Recent activity */
.activity-list{display:flex;flex-direction:column;gap:0}
.act-row{display:flex;align-items:center;gap:12px;padding:10px 12px;border-bottom:1px solid var(--border);font-size:12px;font-weight:500}
.act-row:last-child{border-bottom:none}.act-row:hover{background:var(--red-dim)}
.act-ico{font-size:14px;flex-shrink:0;width:20px;text-align:center}
.act-text{flex:1;color:var(--tx2)}.act-text strong{color:var(--tx)}
.act-time{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx3)}
.info{background:var(--red-dim);border:1px solid var(--border2);border-radius:2px;padding:10px 14px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tx2);margin-bottom:14px;letter-spacing:.5px;border-left:3px solid var(--red)}
.pg2{display:grid;grid-template-columns:1fr 1fr}
.pi{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-bottom:1px solid var(--border)}.pi:nth-child(odd){border-right:1px solid var(--border)}
.pi-name{font-size:12px;font-weight:700;letter-spacing:.3px}.pi-sub{font-size:10px;color:var(--tx3);font-family:'JetBrains Mono',monospace}
.wt{width:100%;border-collapse:collapse;font-size:12px}
.wt th{text-align:left;padding:8px 10px;font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:1.5px;border-bottom:1px solid var(--border2)}
.wt td{padding:9px 10px;border-bottom:1px solid var(--border);font-weight:500}.wt tr:hover td{background:var(--red-dim)}
.badge{display:inline-block;padding:2px 8px;border-radius:2px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;font-family:'JetBrains Mono',monospace}
.badge-eo{background:rgba(192,57,43,.2);color:var(--red3);border:1px solid rgba(192,57,43,.3)}
.badge-sa{background:rgba(212,168,67,.1);color:var(--gold);border:1px solid rgba(212,168,67,.2)}
.badge-tu{background:rgba(240,240,240,.05);color:var(--tx2);border:1px solid var(--border2)}
.pm-row{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid var(--border)}.pm-row:last-child{border-bottom:none}
.pm-info{display:flex;align-items:center;gap:10px}
.btn-rm{background:rgba(192,57,43,.1);border:1px solid rgba(192,57,43,.2);color:var(--red2);border-radius:2px;padding:3px 10px;font-size:10px;font-weight:700;letter-spacing:1px;cursor:pointer;font-family:'JetBrains Mono',monospace;transition:all .15s;text-transform:uppercase}.btn-rm:hover{background:rgba(192,57,43,.25)}
.add-row{display:grid;grid-template-columns:1fr 1fr auto;gap:10px;margin-top:14px;align-items:end}
.slide-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;opacity:0;pointer-events:none;transition:opacity .25s}.slide-overlay.open{opacity:1;pointer-events:all}
.slide-panel{position:fixed;top:0;right:-280px;width:260px;height:100vh;background:var(--bg2);border-left:1px solid var(--border);z-index:201;transition:right .25s;display:flex;flex-direction:column;overflow-y:auto}.slide-panel.open{right:0}
.sp-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--border)}
.sp-title{font-family:'Bebas Neue',cursive;font-size:20px;letter-spacing:3px;color:var(--red2)}
.sp-close{background:none;border:none;color:var(--tx2);cursor:pointer;font-size:18px}
.sp-user{display:flex;align-items:center;gap:10px;padding:14px 18px;border-bottom:1px solid var(--border)}
.sp-av{width:36px;height:36px;border-radius:3px;background:var(--bg4);border:1px solid var(--border2)}
.sp-uname{font-size:13px;font-weight:700;letter-spacing:.5px}.sp-uid{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx3);letter-spacing:.5px}
.sp-links{padding:10px 8px;flex:1}
.sp-link{display:flex;align-items:center;gap:10px;padding:10px 10px;border-radius:2px;cursor:pointer;color:var(--tx2);font-size:13px;font-weight:600;letter-spacing:.5px;transition:.15s;text-decoration:none}.sp-link:hover{background:var(--red-dim);color:var(--tx)}.sp-link.active{color:var(--red3)}
.sp-logout{margin:10px;padding:10px;background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.2);border-radius:2px;color:var(--red2);font-size:12px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-align:center;cursor:pointer;text-decoration:none;display:block;transition:.15s;font-family:'Rajdhani',sans-serif}.sp-logout:hover{background:rgba(192,57,43,.2)}
#toast{position:fixed;bottom:20px;right:20px;background:var(--bg2);border:1px solid var(--border2);border-radius:2px;padding:10px 16px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.5px;opacity:0;transform:translateY(8px);transition:all .25s;pointer-events:none;z-index:9999;max-width:280px}
#toast.show{opacity:1;transform:translateY(0)}#toast.success{border-color:rgba(39,174,96,.4);color:#2ecc71}#toast.error{border-color:rgba(255,50,50,.4);color:#ff6b6b}
@media(max-width:700px){.sidebar{transform:translateX(-100%)}.sidebar.mob-open{transform:translateX(0)}.main{margin-left:0}.hamburger{display:flex}.fr{grid-template-columns:1fr}.pg2{grid-template-columns:1fr}.add-row{grid-template-columns:1fr 1fr;grid-template-rows:auto auto}.add-row .btn-save{grid-column:1/-1}.lnav-links .lnav-link{display:none}.feat-status{grid-template-columns:1fr 1fr}}
/* ── MUSIC MINI PLAYER (sidebar) ── */
.sb-music{border-top:1px solid var(--border);background:var(--bg);flex-shrink:0}
.sb-music-hdr{display:flex;align-items:center;justify-content:space-between;padding:8px 14px;cursor:pointer;user-select:none;transition:.15s}
.sb-music-hdr:hover{background:var(--bg3)}
.sb-music-title{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:2px;text-transform:uppercase;display:flex;align-items:center;gap:6px}
.sb-music-dot{width:6px;height:6px;border-radius:50%;background:var(--tx3);flex-shrink:0;transition:.3s}
.sb-music-dot.playing{background:var(--green);box-shadow:0 0 6px var(--green);animation:pulse-dot 1.5s infinite}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}
.sb-music-chevron{color:var(--tx3);font-size:10px;transition:transform .2s}
.sb-music-chevron.open{transform:rotate(180deg)}
.sb-music-body{display:none;padding:0 14px 12px}
.sb-music-body.open{display:block}
.sb-music-track{padding:8px 0 6px;border-bottom:1px solid var(--border);margin-bottom:8px}
.sb-music-name{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.3px;color:var(--tx)}
.sb-music-src{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:1px;margin-top:2px}
.sb-music-vc{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.sb-vc-badge{font-family:'JetBrains Mono',monospace;font-size:9px;padding:2px 8px;border-radius:2px;letter-spacing:1px}
.sb-vc-badge.in{background:rgba(39,174,96,.12);color:var(--green);border:1px solid rgba(39,174,96,.25)}
.sb-vc-badge.out{background:var(--red-dim);color:var(--tx3);border:1px solid var(--border2)}
.sb-vc-btn{font-family:'JetBrains Mono',monospace;font-size:9px;padding:3px 9px;border-radius:2px;cursor:pointer;border:1px solid;letter-spacing:.5px;text-transform:uppercase;transition:.15s}
.sb-vc-btn.join{background:rgba(39,174,96,.1);color:var(--green);border-color:rgba(39,174,96,.25)}.sb-vc-btn.join:hover{background:rgba(39,174,96,.2)}
.sb-vc-btn.leave{background:var(--red-dim);color:var(--red2);border-color:rgba(192,57,43,.25)}.sb-vc-btn.leave:hover{background:rgba(192,57,43,.25)}
.sb-music-ctrls{display:flex;align-items:center;justify-content:center;gap:2px;margin-bottom:8px}
.sb-ctrl{background:none;border:none;color:var(--tx2);cursor:pointer;font-size:14px;padding:5px 7px;border-radius:2px;transition:.15s;line-height:1}.sb-ctrl:hover{background:var(--red-dim);color:var(--tx)}.sb-ctrl.active{color:var(--red2)}
.sb-ctrl-play{background:var(--red-dim);border:1px solid var(--border2);color:var(--tx);font-size:13px;padding:5px 10px;border-radius:2px}
.sb-ctrl-play:hover{background:rgba(192,57,43,.25);color:var(--red2)}
.sb-vol{display:flex;align-items:center;gap:6px}
.sb-vol-ico{font-size:10px;color:var(--tx3)}
.sb-vol input[type=range]{height:3px;padding:0;cursor:pointer;accent-color:var(--red2)}
/* ── MUSIC PAGE ── */
.mx-layout{display:grid;grid-template-columns:1fr 320px;gap:14px;align-items:start}
.mx-search{display:flex;gap:8px;margin-bottom:14px}
.mx-search input{flex:1}
.mx-search select{width:130px;flex-shrink:0}
.mx-search .btn-save{margin-top:0;padding:10px 16px;white-space:nowrap}
.mx-np{display:flex;gap:14px;align-items:center;padding:14px 0;border-bottom:1px solid var(--border);margin-bottom:14px}
.mx-art{width:56px;height:56px;border-radius:2px;background:var(--bg3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;overflow:hidden}
.mx-art img{width:100%;height:100%;object-fit:cover}
.mx-info{flex:1;min-width:0}
.mx-track-name{font-size:14px;font-weight:700;letter-spacing:.3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mx-track-sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:1px;margin-top:3px}
.mx-track-dur{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx2);margin-top:4px}
.mx-prog{height:3px;background:var(--bg4);border-radius:2px;margin:10px 0 2px;overflow:hidden;position:relative}
.mx-prog-bar{height:100%;background:var(--red2);border-radius:2px;width:0%;transition:width .5s linear}
.mx-ctrls{display:flex;align-items:center;justify-content:center;gap:4px;margin:10px 0}
.mx-btn{background:var(--bg3);border:1px solid var(--border2);color:var(--tx2);cursor:pointer;font-size:13px;padding:7px 12px;border-radius:2px;transition:.15s;line-height:1;font-family:'Rajdhani',sans-serif;font-weight:700}.mx-btn:hover{background:var(--bg4);color:var(--tx)}
.mx-btn.primary{background:var(--red);color:#fff;border-color:var(--red2);font-size:14px;padding:8px 18px}.mx-btn.primary:hover{background:var(--red2)}
.mx-btn.active{color:var(--red2);border-color:rgba(192,57,43,.3)}
.mx-vol-row{display:flex;align-items:center;gap:10px;margin:8px 0}
.mx-vol-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);letter-spacing:1px;white-space:nowrap}
.mx-vol-val{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--red2);width:32px;text-align:right}
.mx-vol-row input[type=range]{flex:1;height:4px;accent-color:var(--red2);cursor:pointer}
.mx-queue-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-bottom:1px solid var(--border);transition:.15s}
.mx-queue-item:last-child{border-bottom:none}
.mx-queue-item:hover{background:var(--red-dim)}
.mx-q-num{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tx3);width:18px;text-align:center;flex-shrink:0}
.mx-q-info{flex:1;min-width:0}
.mx-q-name{font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mx-q-src{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);margin-top:1px}
.mx-q-dur{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx2)}
.mx-q-rm{background:none;border:none;color:var(--tx3);cursor:pointer;font-size:12px;padding:3px 6px;border-radius:2px;transition:.15s}.mx-q-rm:hover{color:var(--red2);background:var(--red-dim)}
.mx-filter-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border)}
.mx-filter-btn{background:var(--bg2);border:none;color:var(--tx2);cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:9px;padding:10px 8px;text-align:center;letter-spacing:1px;transition:.15s;text-transform:uppercase}.mx-filter-btn:hover{background:var(--bg3);color:var(--tx)}
.mx-filter-btn.active{background:var(--red-dim);color:var(--red3)}
.mx-vc-card{background:var(--bg2);border:1px solid var(--border);border-radius:2px;padding:16px;margin-bottom:14px}
.mx-vc-status{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.mx-vc-info{flex:1}
.mx-vc-name{font-size:13px;font-weight:700;letter-spacing:.3px}
.mx-vc-sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);margin-top:3px}
.mx-vc-actions{display:flex;gap:6px}
@media(max-width:900px){.mx-layout{grid-template-columns:1fr}}
@media(max-width:700px){.mx-search{flex-wrap:wrap}.mx-search select{width:100%}}

</style>
</head>
<body>

<!-- ══ LANDING ══ -->
<div id="landing" style="display:flex;flex-direction:column;min-height:100vh">
  <nav class="lnav">
    <div class="lnav-logo">Sentrax<span>™</span></div>
    <div class="lnav-links">
      <a class="lnav-link" href="#features">Features</a>
      <a class="lnav-link" href="#how">How It Works</a>
      <a class="lnav-link" href="/auth/login">Login</a>
      <a class="lnav-btn" href="/auth/login">Open Dashboard</a>
    </div>
  </nav>
  <div class="hero">
    <div class="hero-grid"></div>
    <div class="hero-badge">⚡ v8.4 — Stable &amp; Protected</div>
    <h1 class="hero-title">The<br/><span class="accent">Ultimate</span><br/>Discord Bot<span class="hero-tm">™</span></h1>
    <p class="hero-sub">Military-grade moderation, <strong>antinuke protection</strong>, economy, music, leveling and 200+ commands — all in one powerful bot. Built for serious server owners who demand reliability.</p>
    <a class="btn-hero" href="/auth/login">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
      Enter Dashboard
    </a>
    <div class="hero-stats">
      <div class="hstat"><div class="hstat-val">200+</div><div class="hstat-lbl">Commands</div></div>
      <div class="hstat"><div class="hstat-val">99.9%</div><div class="hstat-lbl">Uptime</div></div>
      <div class="hstat"><div class="hstat-val">15+</div><div class="hstat-lbl">Protections</div></div>
      <div class="hstat"><div class="hstat-val">Free</div><div class="hstat-lbl">Always</div></div>
    </div>
  </div>

  <div class="land-section" id="features">
    <div class="section-tag">Features</div>
    <h2 class="section-title">Everything You Need</h2>
    <p class="section-sub">Built for serious server owners. No compromises, no paywalls on core features.</p>
    <div class="feat-grid">
      <div class="fc"><span class="fc-ico">☢️</span><div class="fc-name">Antinuke</div><div class="fc-desc">15+ real-time protections against raids, mass bans, channel deletions and server takeovers. Panic mode included.</div></div>
      <div class="fc"><span class="fc-ico">🛡️</span><div class="fc-name">Automod</div><div class="fc-desc">Smart spam, invite, mention, caps, zalgo, phishing and custom bad word filtering with per-channel bypass.</div></div>
      <div class="fc"><span class="fc-ico">🎵</span><div class="fc-name">Music</div><div class="fc-desc">High quality Lavalink music with queue management, audio filters, 24/7 mode and playlist support.</div></div>
      <div class="fc"><span class="fc-ico">📈</span><div class="fc-name">Leveling</div><div class="fc-desc">XP system with rank cards, leaderboards, level-up roles and fully custom level-up messages.</div></div>
      <div class="fc"><span class="fc-ico">💰</span><div class="fc-name">Economy</div><div class="fc-desc">Full economy with daily rewards, work, heists, fishing, mining, shops and item trading.</div></div>
      <div class="fc"><span class="fc-ico">⚖️</span><div class="fc-name">Moderation</div><div class="fc-desc">Ban, kick, warn, mute, purge, lockdown with full case logging and warning history.</div></div>
      <div class="fc"><span class="fc-ico">🎫</span><div class="fc-name">Tickets</div><div class="fc-desc">Full support ticket system with categories, transcripts, staff roles and custom welcome messages.</div></div>
      <div class="fc"><span class="fc-ico">🤖</span><div class="fc-name">Auto-Responder</div><div class="fc-desc">Automatic keyword-based responses with custom triggers and reply messages.</div></div>
      <div class="fc"><span class="fc-ico">📋</span><div class="fc-name">Logging</div><div class="fc-desc">12 separate log channels for mod actions, messages, joins, voice, roles, security and more.</div></div>
    </div>
  </div>

  <div class="land-section" id="how" style="padding-top:0">
    <div class="section-tag">Setup</div>
    <h2 class="section-title">How It Works</h2>
    <p class="section-sub">Get started in minutes.</p>
    <div class="steps">
      <div class="step"><div class="step-num">01</div><div class="step-title">Add Bot</div><div class="step-desc">Invite Sentrax to your Discord server with the required permissions.</div></div>
      <div class="step"><div class="step-num">02</div><div class="step-title">Login</div><div class="step-desc">Sign in with Discord OAuth2 — no password, no email required.</div></div>
      <div class="step"><div class="step-num">03</div><div class="step-title">Configure</div><div class="step-desc">Select your server and configure every feature from this dashboard.</div></div>
      <div class="step"><div class="step-num">04</div><div class="step-title">Done</div><div class="step-desc">All changes save directly to the bot in real-time. Instant effect.</div></div>
    </div>
  </div>

  <div style="flex:1"></div>
  <footer class="lfooter">
    <div class="lfooter-logo">Sentrax™</div>
    <div style="display:flex;align-items:center;gap:20px">
      <a href="https://discord.gg/9TmPRaf3Yw" style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--red2);text-decoration:none;letter-spacing:1px">Support Server ↗</a>
      <div class="lfooter-copy">// © 2026 Sentrax. All rights reserved.</div>
    </div>
  </footer>
</div>

<!-- ══ APP ══ -->
<div id="app">
  <aside class="sidebar" id="sidebar">
    <div class="sb-top">
      <div class="sb-logo">Sentrax</div>
      <div class="sb-logo-tm">™ Control Panel</div>
    </div>
    <div class="sb-server" id="serverBtn" onclick="showGuildPicker()">
      <div class="sb-server-icon" id="sbIcon"></div>
      <div class="sb-server-name" id="sbName">Select Server</div>
      <div class="sb-server-arr">▾</div>
    </div>
    <nav class="snav">
      <div class="snav-label">General</div>
      <div class="ni active" data-page="overview" onclick="sp('overview')"><span class="ni-ico">⚡</span>Overview</div>
      <div class="snav-label">Config</div>
      <div class="ni" data-page="welcome" onclick="sp('welcome')"><span class="ni-ico">👋</span>Welcome</div>
      <div class="ni" data-page="leave" onclick="sp('leave')"><span class="ni-ico">🚪</span>Leave</div>
      <div class="ni" data-page="logging" onclick="sp('logging')"><span class="ni-ico">📋</span>Logging</div>
      <div class="ni" data-page="automod" onclick="sp('automod')"><span class="ni-ico">🛡️</span>Automod</div>
      <div class="ni" data-page="antinuke" onclick="sp('antinuke')"><span class="ni-ico">☢️</span>Antinuke</div>
      <div class="ni" data-page="leveling" onclick="sp('leveling')"><span class="ni-ico">📈</span>Leveling</div>
      <div class="ni" data-page="tickets" onclick="sp('tickets')"><span class="ni-ico">🎫</span>Tickets</div>
      <div class="ni" data-page="joinrole" onclick="sp('joinrole')"><span class="ni-ico">🏷️</span>Join Roles</div>
      <div class="ni" data-page="autoresponder" onclick="sp('autoresponder')"><span class="ni-ico">🤖</span>Auto-Responder</div>
      <div class="snav-label">Tools</div>
      <div class="ni" data-page="music" onclick="sp('music')"><span class="ni-ico">🎵</span>Music</div>
      <div class="snav-label">Admin</div>
      <div class="ni" data-page="moderation" onclick="sp('moderation')"><span class="ni-ico">⚖️</span>Moderation</div>
      <div class="ni" data-page="permits" onclick="sp('permits')"><span class="ni-ico">🔑</span>Permits</div>
    </nav>
    <!-- ── Music Mini Player ── -->
    <div class="sb-music" id="sbMusic">
      <div class="sb-music-hdr" onclick="toggleMiniPlayer()">
        <div class="sb-music-title"><div class="sb-music-dot" id="sbMusicDot"></div>Music Player</div>
        <div class="sb-music-chevron" id="sbMusicChevron">▲</div>
      </div>
      <div class="sb-music-body" id="sbMusicBody">
        <div class="sb-music-track">
          <div class="sb-music-name" id="sbTrackName">// nothing playing</div>
          <div class="sb-music-src" id="sbTrackSrc"></div>
        </div>
        <div class="sb-music-vc">
          <div class="sb-vc-badge out" id="sbVcBadge">NOT IN VC</div>
          <button class="sb-vc-btn join" id="sbVcBtn" onclick="miniVcAction()">JOIN VC</button>
        </div>
        <div class="sb-music-ctrls">
          <button class="sb-ctrl" onclick="miniCmd('shuffle')" id="sbShuffleBtn" title="Shuffle">⇄</button>
          <button class="sb-ctrl" onclick="miniCmd('previous')" title="Previous">⏮</button>
          <button class="sb-ctrl sb-ctrl-play" onclick="miniPlayPause()" id="sbPlayBtn">▶</button>
          <button class="sb-ctrl" onclick="miniCmd('skip')" title="Skip">⏭</button>
          <button class="sb-ctrl" onclick="miniCmd('stop')" title="Stop">⏹</button>
          <button class="sb-ctrl" onclick="miniCmd('loop')" id="sbLoopBtn" title="Loop">↻</button>
        </div>
        <div class="sb-vol">
          <span class="sb-vol-ico">🔈</span>
          <input type="range" min="0" max="100" value="80" style="flex:1" oninput="miniVolume(this.value)" id="sbVolSlider"/>
          <span class="sb-vol-ico">🔊</span>
        </div>
      </div>
    </div>
    <div class="sb-user">
      <img class="sb-av" id="sbAv" src=""/>
      <div style="flex:1;min-width:0"><div class="sb-uname" id="sbUname">...</div></div>
      <button class="sb-switch" onclick="switchAccount()" title="Switch Account">⇄</button>
      <a href="/auth/logout" class="sb-out" title="Logout">⏻</a>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="tb-crumb" id="tbCrumb"><span>Sentrax</span> / Select a server</div>
      <button class="hamburger" id="hamburger" onclick="toggleSlide()"><span></span><span></span><span></span></button>
    </div>

    <div id="guild-picker">
      <div class="page-header"><div class="page-title">Your Servers</div><div class="page-sub">// only servers where bot is present and you have access</div></div>
      <div class="gp-empty" id="gp-empty" style="display:none">// no servers found — make sure bot is running and you have extraowner permission</div>
      <div class="guilds-grid" id="guildsGrid"></div>
    </div>

    <div class="content" id="dash-content" style="display:none">

      <!-- ── OVERVIEW ── -->
      <div id="page-overview" class="page-section">
        <div class="page-header"><div class="page-title">Overview</div><div class="page-sub">// server at a glance</div></div>
        <!-- Stats row -->
        <div class="sg" id="statsGrid"></div>
        <!-- Feature status -->
        <div class="card">
          <div class="card-title">📡 Feature Status</div>
          <div class="feat-status" id="featStatus"></div>
        </div>
        <!-- Bot prefix -->
        <div class="card"><div class="card-title">⚙️ Bot Prefix</div>
          <div class="fr">
            <div class="fg"><label>Command Prefix</label><input type="text" id="prefixInput" maxlength="5" placeholder="!"/></div>
            <div class="fg" style="justify-content:flex-end"><label style="visibility:hidden">x</label><button class="btn-save" style="margin-top:0;width:100%" onclick="savePrefix()">Save Prefix</button></div>
          </div>
        </div>
        <!-- Recent warnings -->
        <div class="card">
          <div class="card-title">⚠️ Recent Warnings</div>
          <div style="overflow-x:auto"><table class="wt"><thead><tr><th>User ID</th><th>Mod ID</th><th>Reason</th><th>Date</th></tr></thead><tbody id="ovWarnTable"></tbody></table></div>
        </div>
        <!-- Recent cases -->
        <div class="card">
          <div class="card-title">📑 Recent Mod Cases</div>
          <div style="overflow-x:auto"><table class="wt"><thead><tr><th>Action</th><th>Target</th><th>Mod</th><th>Reason</th></tr></thead><tbody id="ovCasesTable"></tbody></table></div>
        </div>
      </div>

      <!-- ── WELCOME ── -->
      <div id="page-welcome" class="page-section">
        <div class="page-header"><div class="page-title">Welcome</div><div class="page-sub">// member join messages</div></div>
        <div class="card"><div class="card-title">👋 Join Message</div>
          <div class="fr"><div class="fg"><label>Channel ID</label><input type="text" id="wc_ch" placeholder="Paste Channel ID"/></div><div class="fg"><label>Message Style</label><select id="wc_emb"><option value="1">Embed</option><option value="0">Plain Text</option></select></div></div>
          <div class="fg" style="margin-bottom:12px"><label>Message — variables: {user} {server} {count}</label><textarea id="wc_msg" rows="3" placeholder="Welcome {user} to {server}! You are member #{count}."></textarea></div>
          <div class="tr"><div><div class="tr-lbl">Send DM on Join</div><div class="tr-sub">Automatically DM new members</div></div><label class="tog"><input type="checkbox" id="wc_dm"/><span class="tog-sl"></span></label></div>
          <div class="fg" style="margin-top:12px;margin-bottom:4px"><label>DM Message — variables: {user} {server}</label><textarea id="wc_dmmsg" rows="2" placeholder="Welcome to {server}! Use /help to get started."></textarea></div>
          <button class="btn-save" onclick="saveWelcome()">💾 Save Welcome</button>
        </div>
      </div>

      <!-- ── LEAVE ── -->
      <div id="page-leave" class="page-section">
        <div class="page-header"><div class="page-title">Leave</div><div class="page-sub">// member leave messages</div></div>
        <div class="card"><div class="card-title">🚪 Leave Message</div>
          <div class="fr"><div class="fg"><label>Channel ID</label><input type="text" id="lv_ch" placeholder="Paste Channel ID"/></div><div class="fg"><label>Message Style</label><select id="lv_emb"><option value="1">Embed</option><option value="0">Plain Text</option></select></div></div>
          <div class="fg" style="margin-bottom:12px"><label>Message — variables: {username} {server}</label><textarea id="lv_msg" rows="2" placeholder="{username} has left {server}."></textarea></div>
          <button class="btn-save" onclick="saveLeave()">💾 Save Leave</button>
        </div>
      </div>

      <!-- ── LOGGING ── -->
      <div id="page-logging" class="page-section">
        <div class="page-header"><div class="page-title">Logging</div><div class="page-sub">// paste channel IDs — leave blank to disable that log</div></div>
        <div class="card"><div class="card-title">📋 Log Channels</div>
          <div class="fr"><div class="fg"><label>Mod Log</label><input type="text" id="lg_mod" placeholder="Channel ID"/></div><div class="fg"><label>Message Log</label><input type="text" id="lg_msg" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Join Log</label><input type="text" id="lg_join" placeholder="Channel ID"/></div><div class="fg"><label>Member Log</label><input type="text" id="lg_member" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Voice Log</label><input type="text" id="lg_voice" placeholder="Channel ID"/></div><div class="fg"><label>Roles Log</label><input type="text" id="lg_roles" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Automod Log</label><input type="text" id="lg_am" placeholder="Channel ID"/></div><div class="fg"><label>Antinuke Log</label><input type="text" id="lg_an" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Guild Log</label><input type="text" id="lg_guild" placeholder="Channel ID"/></div><div class="fg"><label>Security Log</label><input type="text" id="lg_security" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Ticket Log</label><input type="text" id="lg_ticket" placeholder="Channel ID"/></div><div class="fg"><label>Bot Log</label><input type="text" id="lg_bot" placeholder="Channel ID"/></div></div>
          <button class="btn-save" onclick="saveLogging()">💾 Save Logging</button>
        </div>
      </div>

      <!-- ── AUTOMOD ── -->
      <div id="page-automod" class="page-section">
        <div class="page-header"><div class="page-title">Automod</div><div class="page-sub">// automated moderation filters</div></div>
        <div class="card">
          <div class="card-hdr"><div class="card-title" style="margin-bottom:0">🛡️ Automod Settings</div><label class="tog"><input type="checkbox" id="am_en"/><span class="tog-sl"></span></label></div>
          <div class="fg" style="margin-bottom:12px"><label>Log Channel ID</label><input type="text" id="am_log" placeholder="Channel ID"/></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Spam</div><div class="tr-sub">Detect and block message flooding</div></div><label class="tog"><input type="checkbox" id="am_spam"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Invite</div><div class="tr-sub">Block Discord server invite links</div></div><label class="tog"><input type="checkbox" id="am_invite"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Mention</div><div class="tr-sub">Limit mass user/role mentions</div></div><label class="tog"><input type="checkbox" id="am_mention"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Caps</div><div class="tr-sub">Block excessive capital letters</div></div><label class="tog"><input type="checkbox" id="am_caps"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Link</div><div class="tr-sub">Block external website links</div></div><label class="tog"><input type="checkbox" id="am_link"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-NSFW</div><div class="tr-sub">Block NSFW content detection</div></div><label class="tog"><input type="checkbox" id="am_nsfw"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Phishing</div><div class="tr-sub">Block known scam/phishing links</div></div><label class="tog"><input type="checkbox" id="am_phish"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Zalgo</div><div class="tr-sub">Block zalgo/corrupted text</div></div><label class="tog"><input type="checkbox" id="am_zalgo"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Alt</div><div class="tr-sub">Block new/alt accounts</div></div><label class="tog"><input type="checkbox" id="am_alt"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Bad Words Filter</div><div class="tr-sub">Block custom blacklisted words</div></div><label class="tog"><input type="checkbox" id="am_words"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Sticker</div><div class="tr-sub">Block sticker messages</div></div><label class="tog"><input type="checkbox" id="am_sticker"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Emoji</div><div class="tr-sub">Limit excessive emoji usage</div></div><label class="tog"><input type="checkbox" id="am_emoji"/><span class="tog-sl"></span></label></div>
          <button class="btn-save" onclick="saveAutomod()">💾 Save Automod</button>
        </div>
      </div>

      <!-- ── ANTINUKE ── -->
      <div id="page-antinuke" class="page-section">
        <div class="page-header"><div class="page-title">Antinuke</div><div class="page-sub">// raid &amp; server takeover protection</div></div>
        <div class="card">
          <div class="card-hdr"><div class="card-title" style="margin-bottom:0">☢️ Antinuke Settings</div><label class="tog"><input type="checkbox" id="an_en"/><span class="tog-sl"></span></label></div>
          <div class="fr"><div class="fg"><label>Punishment Action</label><select id="an_punish"><option value="ban">Ban</option><option value="kick">Kick</option><option value="strip">Strip Roles</option></select></div><div class="fg"><label>Log Channel ID</label><input type="text" id="an_log" placeholder="Channel ID"/></div></div>
          <div class="tr"><div><div class="tr-lbl">Panic Mode</div><div class="tr-sub">Emergency full server lockdown</div></div><label class="tog"><input type="checkbox" id="an_panic"/><span class="tog-sl"></span></label></div>
          <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3);padding:12px 0 6px;text-transform:uppercase;letter-spacing:1.5px">// Active Protections</div>
          <div class="pg2">
            <div class="pi"><div><div class="pi-name">Anti-Ban</div><div class="pi-sub">Mass ban detection</div></div><label class="tog"><input type="checkbox" id="an_ban"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Kick</div><div class="pi-sub">Mass kick detection</div></div><label class="tog"><input type="checkbox" id="an_kick"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Bot Add</div><div class="pi-sub">Unverified bot prevention</div></div><label class="tog"><input type="checkbox" id="an_bot"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Ch Create</div><div class="pi-sub">Mass channel create</div></div><label class="tog"><input type="checkbox" id="an_ch_c"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Ch Delete</div><div class="pi-sub">Mass channel delete</div></div><label class="tog"><input type="checkbox" id="an_ch_d"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Ch Update</div><div class="pi-sub">Channel edit abuse</div></div><label class="tog"><input type="checkbox" id="an_ch_u"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Role Create</div><div class="pi-sub">Mass role create</div></div><label class="tog"><input type="checkbox" id="an_rl_c"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Role Delete</div><div class="pi-sub">Mass role delete</div></div><label class="tog"><input type="checkbox" id="an_rl_d"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Role Update</div><div class="pi-sub">Permission abuse</div></div><label class="tog"><input type="checkbox" id="an_rl_u"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Webhook Create</div><div class="pi-sub">Unauthorized webhooks</div></div><label class="tog"><input type="checkbox" id="an_wh_c"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Webhook Delete</div><div class="pi-sub">Webhook deletion</div></div><label class="tog"><input type="checkbox" id="an_wh_d"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Everyone</div><div class="pi-sub">@everyone ping abuse</div></div><label class="tog"><input type="checkbox" id="an_everyone"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Guild Update</div><div class="pi-sub">Server setting tampering</div></div><label class="tog"><input type="checkbox" id="an_guild"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Prune</div><div class="pi-sub">Mass member prune</div></div><label class="tog"><input type="checkbox" id="an_prune"/><span class="tog-sl"></span></label></div>
          </div>
          <button class="btn-save" onclick="saveAntinuke()">💾 Save Antinuke</button>
        </div>
      </div>

      <!-- ── LEVELING ── -->
      <div id="page-leveling" class="page-section">
        <div class="page-header"><div class="page-title">Leveling</div><div class="page-sub">// xp &amp; rank system configuration</div></div>
        <div class="card">
          <div class="card-hdr"><div class="card-title" style="margin-bottom:0">📈 Leveling Settings</div><label class="tog"><input type="checkbox" id="lev_en"/><span class="tog-sl"></span></label></div>
          <div class="fr"><div class="fg"><label>Level-Up Channel ID</label><input type="text" id="lev_ch" placeholder="Channel ID (leave blank for same channel)"/></div><div class="fg"><label>XP Per Message</label><input type="number" id="lev_xp" min="1" max="100" placeholder="15"/></div></div>
          <div class="fr"><div class="fg"><label>XP Min Per Message</label><input type="number" id="lev_xpmin" placeholder="15"/></div><div class="fg"><label>XP Max Per Message</label><input type="number" id="lev_xpmax" placeholder="25"/></div></div>
          <div class="fr"><div class="fg"><label>XP Cooldown (seconds)</label><input type="number" id="lev_cd" placeholder="60"/></div></div>
          <div class="fg" style="margin-bottom:12px"><label>Level-Up Message — {user} {level}</label><input type="text" id="lev_msg" placeholder="{user} leveled up to level {level}! 🎉"/></div>
          <button class="btn-save" onclick="saveLeveling()">💾 Save Leveling</button>
        </div>
      </div>

      <!-- ── TICKETS ── -->
      <div id="page-tickets" class="page-section">
        <div class="page-header"><div class="page-title">Tickets</div><div class="page-sub">// support ticket system configuration</div></div>
        <div class="card"><div class="card-title">🎫 Ticket Config</div>
          <div class="fr"><div class="fg"><label>Ticket Category ID</label><input type="text" id="tk_cat" placeholder="Category ID"/></div><div class="fg"><label>Log Channel ID</label><input type="text" id="tk_log" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Support Role ID</label><input type="text" id="tk_role" placeholder="Role ID"/></div><div class="fg"><label>Transcript Channel ID</label><input type="text" id="tk_trans" placeholder="Channel ID"/></div></div>
          <div class="fg" style="margin-bottom:12px"><label>Ticket Welcome Message</label><textarea id="tk_msg" rows="3" placeholder="Welcome! A support member will assist you shortly. Please describe your issue."></textarea></div>
          <button class="btn-save" onclick="saveTickets()">💾 Save Tickets</button>
        </div>
      </div>

      <!-- ── JOIN ROLES ── -->
      <div id="page-joinrole" class="page-section">
        <div class="page-header"><div class="page-title">Join Roles</div><div class="page-sub">// roles automatically assigned on member join</div></div>
        <div class="card">
          <div class="card-title">🏷️ Auto-Assign Roles</div>
          <div class="info">Roles listed here are automatically given to members (or bots) when they join your server.</div>
          <div id="joinroleList"></div>
          <div class="add-row" style="grid-template-columns:1fr auto auto">
            <div class="fg"><label>Role ID</label><input type="text" id="jr_role" placeholder="Paste Role ID"/></div>
            <div class="fg"><label>Bot Only?</label><select id="jr_bot"><option value="0">All Members</option><option value="1">Bots Only</option></select></div>
            <button class="btn-save" style="margin-top:0" onclick="addJoinRole()">+ Add</button>
          </div>
        </div>
      </div>

      <!-- ── AUTO-RESPONDER ── -->
      <div id="page-autoresponder" class="page-section">
        <div class="page-header"><div class="page-title">Auto-Responder</div><div class="page-sub">// keyword triggered automatic responses</div></div>
        <div class="card">
          <div class="card-title">🤖 Active Triggers</div>
          <div class="info">Use <code>/autoresponder add</code> in Discord to add triggers. This page shows your current active ones.</div>
          <div id="arList"><div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:'JetBrains Mono',monospace">// loading...</div></div>
        </div>
      </div>

      <!-- ── MODERATION ── -->
      <div id="page-moderation" class="page-section">
        <div class="page-header"><div class="page-title">Moderation</div><div class="page-sub">// cases &amp; warnings history</div></div>
        <div class="sg" id="modStats"></div>
        <div class="card"><div class="card-title">⚠️ Recent Warnings</div><div style="overflow-x:auto"><table class="wt"><thead><tr><th>User ID</th><th>Mod ID</th><th>Reason</th><th>Date</th></tr></thead><tbody id="warnTable"></tbody></table></div></div>
        <div class="card"><div class="card-title">📑 Mod Cases</div><div style="overflow-x:auto"><table class="wt"><thead><tr><th>Action</th><th>Target</th><th>Mod</th><th>Reason</th></tr></thead><tbody id="casesTable"></tbody></table></div></div>
      </div>

      <!-- ── PERMITS ── -->
      <div id="page-permits" class="page-section">
        <div class="page-header"><div class="page-title">Permits</div><div class="page-sub">// dashboard &amp; bot access control</div></div>
        <div class="info"><strong>extraowner</strong> — full dashboard access. <strong>serveradmin</strong> — limited bot commands. <strong>trustuser</strong> — trusted user commands only.</div>
        <div class="card"><div class="card-title">🔑 Current Permissions</div>
          <div id="permsList"></div>
          <div class="add-row">
            <div class="fg"><label>User / Role ID</label><input type="text" id="pm_id" placeholder="Paste Discord ID"/></div>
            <div class="fg"><label>Permission Level</label><select id="pm_level"><option value="extraowner">extraowner</option><option value="serveradmin">serveradmin</option><option value="trustuser">trustuser</option></select></div>
            <button class="btn-save" style="margin-top:0" onclick="addPermit()">+ Add</button>
          </div>
        </div>
      </div>


      <!-- ── MUSIC ── -->
      <div id="page-music" class="page-section">
        <div class="page-header"><div class="page-title">Music</div><div class="page-sub">// bot music player — requires bot in a voice channel</div></div>

        <!-- VC Status Card -->
        <div class="mx-vc-card" id="mxVcCard">
          <div class="mx-vc-status">
            <div class="mx-vc-info">
              <div class="mx-vc-name" id="mxVcName">Checking voice channel...</div>
              <div class="mx-vc-sub" id="mxVcSub">// fetching bot status</div>
            </div>
            <div class="mx-vc-actions">
              <button class="btn-save" style="margin-top:0;padding:8px 16px" id="mxJoinBtn" onclick="mxJoinLeave()">Join VC</button>
            </div>
          </div>
          <div class="info" style="margin-bottom:0;font-size:10px" id="mxVcHint">To make the bot join your VC, make sure you are in a voice channel first.</div>
        </div>

        <!-- Search Bar -->
        <div class="card" style="margin-bottom:14px">
          <div class="card-title">🔍 Search &amp; Play</div>
          <div class="mx-search">
            <select id="mxSource">
              <option value="youtube">▶ YouTube</option>
              <option value="soundcloud">☁ SoundCloud</option>
              <option value="spotify">🎵 Spotify</option>
              <option value="ytsearch">🔎 YT Search</option>
              <option value="scsearch">🔎 SC Search</option>
              <option value="http">🔗 Direct URL</option>
            </select>
            <input type="text" id="mxQuery" placeholder="Song name, URL, or playlist link..." onkeydown="if(event.key==='Enter')mxPlay()"/>
            <button class="btn-save" style="margin-top:0" onclick="mxPlay()">▶ Play</button>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="mx-btn" onclick="mxCmd('playnext')">⏫ Play Next</button>
            <button class="mx-btn" onclick="mxCmd('playskip')">⏭ Play &amp; Skip</button>
          </div>
        </div>

        <div class="mx-layout">
          <!-- LEFT: Now Playing + Controls + Queue -->
          <div>
            <!-- Now Playing -->
            <div class="card" id="mxNpCard">
              <div class="card-title">🎵 Now Playing</div>
              <div class="mx-np">
                <div class="mx-art" id="mxArt">🎵</div>
                <div class="mx-info">
                  <div class="mx-track-name" id="mxTrackName">// nothing playing</div>
                  <div class="mx-track-sub" id="mxTrackSrc">—</div>
                  <div class="mx-track-dur" id="mxTrackDur"></div>
                </div>
              </div>
              <div class="mx-prog"><div class="mx-prog-bar" id="mxProgBar"></div></div>
              <!-- Controls -->
              <div class="mx-ctrls">
                <button class="mx-btn" id="mxShuffleBtn" onclick="mxToggle('shuffle')" title="Shuffle">⇄</button>
                <button class="mx-btn" onclick="mxCmd('previous')" title="Previous">⏮</button>
                <button class="mx-btn primary" id="mxPlayBtn" onclick="mxPlayPause()">⏸ Pause</button>
                <button class="mx-btn" onclick="mxCmd('skip')" title="Skip">⏭</button>
                <button class="mx-btn" onclick="mxCmd('stop')" title="Stop">⏹ Stop</button>
                <button class="mx-btn" id="mxLoopBtn" onclick="mxToggle('loop')" title="Loop">↻ Loop</button>
              </div>
              <!-- Volume -->
              <div class="mx-vol-row">
                <span class="mx-vol-lbl">🔈 VOL</span>
                <input type="range" min="0" max="100" value="80" id="mxVolSlider" oninput="mxVolume(this.value)"/>
                <span class="mx-vol-val" id="mxVolVal">80%</span>
              </div>
              <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap">
                <button class="mx-btn" onclick="mxCmd('clearqueue')">🗑 Clear Queue</button>
                <button class="mx-btn" onclick="mxCmd('disconnect')">📤 Disconnect</button>
                <button class="mx-btn" onclick="loadMusicPage()">↻ Refresh</button>
              </div>
            </div>

            <!-- Queue -->
            <div class="card">
              <div class="card-hdr">
                <div class="card-title" style="margin-bottom:0">📋 Queue</div>
                <span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tx3)" id="mxQueueCount"></span>
              </div>
              <div id="mxQueueList"><div style="color:var(--tx3);font-size:11px;padding:12px 0;font-family:'JetBrains Mono',monospace">// queue is empty</div></div>
            </div>
          </div>

          <!-- RIGHT: Filters + Sources info -->
          <div>
            <!-- Audio Filters -->
            <div class="card">
              <div class="card-title">🎛️ Audio Filters</div>
              <div class="mx-filter-grid" id="mxFilterGrid">
                <button class="mx-filter-btn" data-filter="bassboost" onclick="mxFilter('bassboost',this)">🔊 Bass Boost</button>
                <button class="mx-filter-btn" data-filter="nightcore" onclick="mxFilter('nightcore',this)">🌙 Nightcore</button>
                <button class="mx-filter-btn" data-filter="vaporwave" onclick="mxFilter('vaporwave',this)">🌊 Vaporwave</button>
                <button class="mx-filter-btn" data-filter="8d" onclick="mxFilter('8d',this)">🎧 8D Audio</button>
                <button class="mx-filter-btn" data-filter="karaoke" onclick="mxFilter('karaoke',this)">🎤 Karaoke</button>
                <button class="mx-filter-btn" data-filter="tremolo" onclick="mxFilter('tremolo',this)">〰️ Tremolo</button>
                <button class="mx-filter-btn" data-filter="vibrato" onclick="mxFilter('vibrato',this)">🎶 Vibrato</button>
                <button class="mx-filter-btn" data-filter="rotation" onclick="mxFilter('rotation',this)">🔄 Rotation</button>
                <button class="mx-filter-btn" data-filter="soft" onclick="mxFilter('soft',this)">🌸 Soft</button>
                <button class="mx-filter-btn" data-filter="pop" onclick="mxFilter('pop',this)">🎉 Pop</button>
                <button class="mx-filter-btn" data-filter="earrape" onclick="mxFilter('earrape',this)">💀 Ear Rape</button>
                <button class="mx-filter-btn" data-filter="none" onclick="mxFilter('none',this)">✖ Reset</button>
              </div>
            </div>

            <!-- Supported Sources -->
            <div class="card">
              <div class="card-title">🔗 Supported Sources</div>
              <div style="display:flex;flex-direction:column;gap:6px">
                <div class="pi" style="border:none;padding:6px 0"><div><div class="pi-name">▶ YouTube</div><div class="pi-sub">Videos, playlists, live streams</div></div></div>
                <div class="pi" style="border:none;padding:6px 0"><div><div class="pi-name">☁ SoundCloud</div><div class="pi-sub">Tracks &amp; playlists</div></div></div>
                <div class="pi" style="border:none;padding:6px 0"><div><div class="pi-name">🎵 Spotify</div><div class="pi-sub">Tracks, albums, playlists (via YT)</div></div></div>
                <div class="pi" style="border:none;padding:6px 0"><div><div class="pi-name">🔗 Direct URL</div><div class="pi-sub">Any direct .mp3 / audio stream</div></div></div>
              </div>
              <div class="info" style="margin-top:10px;margin-bottom:0;font-size:10px">Spotify links are resolved via YouTube search through Lavalink. Playlist imports may take a moment.</div>
            </div>

            <!-- Queue Settings -->
            <div class="card">
              <div class="card-title">⚙️ Queue Settings</div>
              <div class="tr"><div><div class="tr-lbl">Autoplay</div><div class="tr-sub">Play related songs when queue ends</div></div><label class="tog"><input type="checkbox" id="mxAutoplay" onchange="mxToggleAutoplay()"/><span class="tog-sl"></span></label></div>
              <div class="tr" style="border-bottom:none"><div><div class="tr-lbl">24/7 Mode</div><div class="tr-sub">Keep bot in VC even when queue ends</div></div><label class="tog"><input type="checkbox" id="mx247" onchange="mxToggle247()"/><span class="tog-sl"></span></label></div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /dash-content -->
  </main>
</div>

<!-- Slide panel -->
<div class="slide-overlay" id="overlay" onclick="closeSlide()"></div>
<div class="slide-panel" id="slidePanel">
  <div class="sp-hdr"><div class="sp-title">Sentrax™</div><button class="sp-close" onclick="closeSlide()">✕</button></div>
  <div class="sp-user"><img class="sp-av" id="spAv" src=""/><div><div class="sp-uname" id="spUname">...</div><div class="sp-uid" id="spUid"></div></div></div>
  <div class="sp-links">
    <div class="sp-link" onclick="sp('overview');closeSlide()">⚡ Overview</div>
    <div class="sp-link" onclick="sp('welcome');closeSlide()">👋 Welcome</div>
    <div class="sp-link" onclick="sp('leave');closeSlide()">🚪 Leave</div>
    <div class="sp-link" onclick="sp('logging');closeSlide()">📋 Logging</div>
    <div class="sp-link" onclick="sp('automod');closeSlide()">🛡️ Automod</div>
    <div class="sp-link" onclick="sp('antinuke');closeSlide()">☢️ Antinuke</div>
    <div class="sp-link" onclick="sp('leveling');closeSlide()">📈 Leveling</div>
    <div class="sp-link" onclick="sp('tickets');closeSlide()">🎫 Tickets</div>
    <div class="sp-link" onclick="sp('joinrole');closeSlide()">🏷️ Join Roles</div>
    <div class="sp-link" onclick="sp('autoresponder');closeSlide()">🤖 Auto-Responder</div>
    <div class="sp-link" onclick="sp('music');closeSlide()">🎵 Music</div>
    <div class="sp-link" onclick="sp('moderation');closeSlide()">⚖️ Moderation</div>
    <div class="sp-link" onclick="sp('permits');closeSlide()">🔑 Permits</div>
  </div>
  <a href="/auth/logout" class="sp-logout" style="margin-bottom:4px">Logout</a>
<a href="javascript:void(0)" onclick="switchAccount()" class="sp-logout" style="background:rgba(212,168,67,.06);border-color:rgba(212,168,67,.2);color:var(--gold)">Switch Account</a>
</div>
<div id="toast"></div>

<script>
let CG=null;
function n(id){return document.getElementById(id);}
function bool(v){return !!Number(v);}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(msg,type){const e=n('toast');e.textContent=(type==='success'?'✓ ':'✗ ')+msg;e.className='show '+(type||'success');clearTimeout(window._tt);window._tt=setTimeout(()=>{e.className='';},3500);}
function getToken(){return localStorage.getItem('snx_token');}
async function api(url,body,method){
  try{
    const o={method:method||'GET',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(getToken()||'')}};
    if(body)o.body=JSON.stringify(body);
    const r=await fetch(url,o);const d=await r.json();
    if(!r.ok){toast(d.error||'API Error','error');return null;}return d;
  }catch(e){toast('Network error: '+e.message,'error');return null;}
}
function gv(id){const e=n(id);return e?e.value.trim():'';}
function sv(id,v){const e=n(id);if(e)e.value=v!==null&&v!==undefined?String(v):'';}
function gc(id){const e=n(id);return e?e.checked:false;}
function sc(id,v){const e=n(id);if(e)e.checked=bool(v);}
function noData(colspan,msg){return `<tr><td colspan="${colspan}" style="color:var(--tx3);text-align:center;padding:20px;font-family:'JetBrains Mono',monospace;font-size:11px">// ${msg}</td></tr>`;}


// ══════════════════════════════════════════════════════════════════
// MUSIC SYSTEM
// ══════════════════════════════════════════════════════════════════
let _mx={playing:false,paused:false,loop:false,shuffle:false,vol:80,inVc:false,vcName:'',filter:'none',autoplay:false,h247:false};
let _mxPollTimer=null;

// ── Helpers ────────────────────────────────────────────────────────
async function mxCmd(cmd,value){
  if(!CG)return toast('Select a server first','error');
  const ok=await api('/api/guild/'+CG.id+'/music-cmd',{cmd,value},'POST');
  if(ok&&ok.error)toast(ok.error,'error');
  setTimeout(loadMusicPage,400);
  return ok;
}

// ── Source label ───────────────────────────────────────────────────
function srcLabel(s){
  if(!s)return '';
  if(s.includes('youtu'))return '▶ YouTube';
  if(s.includes('soundcloud'))return '☁ SoundCloud';
  if(s.includes('spotify'))return '🎵 Spotify';
  return '🔗 '+s.split('/')[2]||s;
}

// ── Load full music page ───────────────────────────────────────────
async function loadMusicPage(){
  if(!CG)return;
  const d=await api('/api/guild/'+CG.id+'/music-cmd');
  updateMusicUI(d);
  updateMiniPlayer(d);
}

function updateMusicUI(d){
  if(!d){
    n('mxVcName').textContent='Bot not connected';
    n('mxVcSub').textContent='// use Join VC to connect';
    n('mxJoinBtn').textContent='Join VC';
    n('mxJoinBtn').style.background='';
    n('mxTrackName').textContent='// nothing playing';
    n('mxTrackSrc').textContent='—';
    n('mxTrackDur').textContent='';
    n('mxQueueList').innerHTML='<div style="color:var(--tx3);font-size:11px;padding:12px 0;font-family:\'JetBrains Mono\',monospace">// queue is empty</div>';
    _mx.inVc=false;
    return;
  }
  // VC status
  _mx.inVc=!!(d.channel_name||d.vc_name||d.in_vc);
  const vcName=d.channel_name||d.vc_name||'';
  n('mxVcName').textContent=_mx.inVc?('🔊 '+vcName):'Not in a voice channel';
  n('mxVcSub').textContent=_mx.inVc?('// playing in: '+vcName):'// use Join VC to connect';
  n('mxJoinBtn').textContent=_mx.inVc?'Leave VC':'Join VC';
  n('mxJoinBtn').style.background=_mx.inVc?'rgba(192,57,43,.2)':'';
  n('mxVcHint').textContent=_mx.inVc
    ?'Bot is in a voice channel. To move it to yours: Leave VC → then Join VC from your channel.'
    :'To make the bot join your VC, make sure you are in a voice channel first.';

  // Now playing
  const track=d.track||d.current||d.now_playing||null;
  if(track){
    _mx.playing=true;
    _mx.paused=!!(d.paused||d.is_paused);
    const title=track.title||track.name||'Unknown Track';
    const src=track.uri||track.url||track.source||'';
    const dur=track.duration?formatDur(track.duration):'';
    n('mxTrackName').textContent=title;
    n('mxTrackSrc').textContent=srcLabel(src);
    n('mxTrackDur').textContent=dur?('⏱ '+dur):'';
    // Thumbnail
    const thumb=track.thumbnail||track.artwork||'';
    n('mxArt').innerHTML=thumb?`<img src="${thumb}" onerror="this.parentElement.textContent='🎵'"/>`:'🎵';
    // Progress bar
    if(track.position!=null&&track.duration){
      const pct=Math.min(100,Math.round((track.position/track.duration)*100));
      n('mxProgBar').style.width=pct+'%';
    }
    n('mxPlayBtn').textContent=_mx.paused?'▶ Resume':'⏸ Pause';
  } else {
    _mx.playing=false;
    n('mxTrackName').textContent='// nothing playing';
    n('mxTrackSrc').textContent='—';
    n('mxTrackDur').textContent='';
    n('mxArt').innerHTML='🎵';
    n('mxProgBar').style.width='0%';
    n('mxPlayBtn').textContent='▶ Play';
  }

  // Volume
  if(d.volume!=null){
    _mx.vol=d.volume;
    n('mxVolSlider').value=d.volume;
    n('mxVolVal').textContent=d.volume+'%';
  }

  // Loop / shuffle / filter state
  _mx.loop=!!(d.loop||d.repeat||d.loop_mode);
  _mx.shuffle=!!(d.shuffle||d.shuffled);
  _mx.autoplay=!!(d.autoplay);
  _mx.h247=!!(d.twentyfour_seven||d['247']);
  n('mxLoopBtn').classList.toggle('active',_mx.loop);
  n('mxShuffleBtn').classList.toggle('active',_mx.shuffle);
  n('mxAutoplay').checked=_mx.autoplay;
  n('mx247').checked=_mx.h247;

  // Active filter
  const cf=d.filter||d.current_filter||'none';
  document.querySelectorAll('.mx-filter-btn').forEach(b=>{
    b.classList.toggle('active',b.dataset.filter===cf);
  });

  // Queue
  const queue=d.queue||[];
  n('mxQueueCount').textContent=queue.length?queue.length+' track'+(queue.length!==1?'s':''):'';
  if(queue.length){
    n('mxQueueList').innerHTML=queue.slice(0,50).map((t,i)=>{
      const title=esc(t.title||t.name||'Unknown');
      const src2=srcLabel(t.uri||t.url||'');
      const dur2=t.duration?formatDur(t.duration):'';
      return `<div class="mx-queue-item">
        <div class="mx-q-num">${i+1}</div>
        <div class="mx-q-info"><div class="mx-q-name">${title}</div><div class="mx-q-src">${src2}</div></div>
        <div class="mx-q-dur">${dur2}</div>
        <button class="mx-q-rm" onclick="mxRemoveQueue(${i+1})" title="Remove">✕</button>
      </div>`;
    }).join('');
    if(queue.length>50)n('mxQueueList').innerHTML+=`<div style="color:var(--tx3);font-family:'JetBrains Mono',monospace;font-size:10px;padding:8px 10px">...and ${queue.length-50} more</div>`;
  } else {
    n('mxQueueList').innerHTML='<div style="color:var(--tx3);font-size:11px;padding:12px 0;font-family:\'JetBrains Mono\',monospace">// queue is empty</div>';
  }
}

function formatDur(ms){
  if(!ms||ms<=0)return '';
  const s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60);
  if(h>0)return h+':'+(m%60).toString().padStart(2,'0')+':'+(s%60).toString().padStart(2,'0');
  return m+':'+(s%60).toString().padStart(2,'0');
}

// ── Mini player update ─────────────────────────────────────────────
function updateMiniPlayer(d){
  if(!d){
    n('sbTrackName').textContent='// nothing playing';
    n('sbTrackSrc').textContent='';
    n('sbMusicDot').classList.remove('playing');
    n('sbPlayBtn').textContent='▶';
    n('sbVcBadge').textContent='NOT IN VC';
    n('sbVcBadge').className='sb-vc-badge out';
    n('sbVcBtn').textContent='JOIN VC';
    n('sbVcBtn').className='sb-vc-btn join';
    _mx.inVc=false;
    return;
  }
  const track=d.track||d.current||d.now_playing||null;
  if(track){
    n('sbTrackName').textContent=track.title||track.name||'Unknown Track';
    n('sbTrackSrc').textContent=srcLabel(track.uri||track.url||'');
    n('sbMusicDot').classList.add('playing');
    n('sbPlayBtn').textContent=(d.paused||d.is_paused)?'▶':'⏸';
  } else {
    n('sbTrackName').textContent='// nothing playing';
    n('sbTrackSrc').textContent='';
    n('sbMusicDot').classList.remove('playing');
    n('sbPlayBtn').textContent='▶';
  }
  _mx.inVc=!!(d.channel_name||d.vc_name||d.in_vc);
  if(_mx.inVc){
    n('sbVcBadge').textContent='IN VC';n('sbVcBadge').className='sb-vc-badge in';
    n('sbVcBtn').textContent='LEAVE';n('sbVcBtn').className='sb-vc-btn leave';
  } else {
    n('sbVcBadge').textContent='NOT IN VC';n('sbVcBadge').className='sb-vc-badge out';
    n('sbVcBtn').textContent='JOIN VC';n('sbVcBtn').className='sb-vc-btn join';
  }
  n('sbLoopBtn').classList.toggle('active',!!(d.loop||d.repeat));
  n('sbShuffleBtn').classList.toggle('active',!!(d.shuffle||d.shuffled));
}

// ── Mini player controls ───────────────────────────────────────────
function toggleMiniPlayer(){
  const body=n('sbMusicBody'),chev=n('sbMusicChevron');
  const open=body.classList.toggle('open');
  chev.classList.toggle('open',open);
  if(open&&CG)loadMusicPage();
}
async function miniCmd(cmd){if(!CG)return toast('Select a server first','error');await mxCmd(cmd);}
async function miniPlayPause(){
  if(!CG)return toast('Select a server first','error');
  if(_mx.playing&&!_mx.paused){await mxCmd('pause');}else{await mxCmd('resume');}
}
async function miniVolume(v){
  _mx.vol=+v;
  clearTimeout(window._sbVolT);
  window._sbVolT=setTimeout(()=>mxCmd('volume',String(v)),400);
}
async function miniVcAction(){
  if(!CG)return toast('Select a server first','error');
  if(_mx.inVc){await mxCmd('leave');}else{await mxCmd('join');}
}

// ── Full page controls ─────────────────────────────────────────────
async function mxPlay(){
  if(!CG)return toast('Select a server first','error');
  const q=n('mxQuery').value.trim();
  if(!q)return toast('Enter a song name or URL','error');
  const src=n('mxSource').value;
  const value=src+':'+q;
  const ok=await api('/api/guild/'+CG.id+'/music-cmd',{cmd:'play',value},'POST');
  if(ok&&!ok.error){toast('▶ Queued: '+q,'success');n('mxQuery').value='';}
  else if(ok&&ok.error)toast(ok.error,'error');
  setTimeout(loadMusicPage,600);
}
async function mxPlayPause(){
  if(_mx.playing&&!_mx.paused)await mxCmd('pause');else await mxCmd('resume');
}
function mxVolume(v){
  n('mxVolVal').textContent=v+'%';
  _mx.vol=+v;
  clearTimeout(window._mxVolT);
  window._mxVolT=setTimeout(()=>mxCmd('volume',String(v)),400);
}
async function mxToggle(type){
  if(type==='loop'){_mx.loop=!_mx.loop;await mxCmd('loop',_mx.loop?'on':'off');}
  if(type==='shuffle'){_mx.shuffle=!_mx.shuffle;await mxCmd('shuffle',_mx.shuffle?'on':'off');}
}
async function mxFilter(filter,btn){
  document.querySelectorAll('.mx-filter-btn').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  _mx.filter=filter;
  await mxCmd('filter',filter);
}
async function mxRemoveQueue(pos){await mxCmd('remove',String(pos));}
async function mxJoinLeave(){
  if(_mx.inVc){await mxCmd('leave');}else{await mxCmd('join');}
}
async function mxToggleAutoplay(){await mxCmd('autoplay',n('mxAutoplay').checked?'on':'off');}
async function mxToggle247(){await mxCmd('247',n('mx247').checked?'on':'off');}


async function init(){
  const params=new URLSearchParams(window.location.search);
  const urlToken=params.get('snx_token');
  if(urlToken){localStorage.setItem('snx_token',urlToken);window.history.replaceState({},'','/');}
  if(params.get('logout')==='1'){localStorage.removeItem('snx_token');window.history.replaceState({},'','/');}
  if(!getToken()){showLanding();return;}
  try{
    const r=await fetch('/api/me',{headers:{'Authorization':'Bearer '+(getToken()||'')}});
    if(!r.ok){localStorage.removeItem('snx_token');showLanding();return;}
    const{user}=await r.json();showApp(user);loadGuilds();
  }catch{showLanding();}
}
function showLanding(){n('landing').style.display='flex';n('app').style.display='none';}
function switchAccount(){localStorage.removeItem('snx_token');window.location.href='/auth/login?switch=1';}
function showApp(u){
  n('landing').style.display='none';n('app').style.display='block';
  const av=u.avatar?`https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.png?size=64`:'https://cdn.discordapp.com/embed/avatars/0.png';
  n('sbAv').src=av;n('sbUname').textContent=u.username;
  n('spAv').src=av;n('spUname').textContent=u.username;n('spUid').textContent=u.id;
}
async function loadGuilds(){
  showGuildPicker();
  const guilds=await api('/api/guilds');const grid=n('guildsGrid');grid.innerHTML='';
  if(!guilds||guilds.length===0){n('gp-empty').style.display='block';return;}
  n('gp-empty').style.display='none';
  guilds.forEach(g=>{
    const c=document.createElement('div');c.className='gc';
    c.innerHTML=`<div class="gc-icon">${g.icon?`<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png?size=64" style="width:100%;height:100%;object-fit:cover" alt=""/>`:g.name.charAt(0)}</div><div class="gc-name">${esc(g.name)}</div>`;
    c.onclick=()=>selectGuild(g);grid.appendChild(c);
  });
}
function showGuildPicker(){
  n('guild-picker').style.display='block';n('dash-content').style.display='none';
  n('tbCrumb').innerHTML='<span>Sentrax</span> / Select a server';
  n('sbName').textContent='Select Server';n('sbIcon').innerHTML='';CG=null;
}
function selectGuild(g){
  CG=g;n('guild-picker').style.display='none';n('dash-content').style.display='block';
  n('tbCrumb').innerHTML=`<span>Sentrax</span> / ${esc(g.name)}`;n('sbName').textContent=g.name;
  n('sbIcon').innerHTML=g.icon?`<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png?size=32" style="width:28px;height:28px;border-radius:3px;object-fit:cover"/>`:g.name.charAt(0);
  sp('overview');
}
function sp(p){
  if(!CG){showGuildPicker();return;}
  document.querySelectorAll('.ni').forEach(e=>e.classList.toggle('active',e.dataset.page===p));
  document.querySelectorAll('.page-section').forEach(e=>e.style.display='none');
  const s=n('page-'+p);if(s)s.style.display='block';
  const loads={overview:loadOverview,welcome:loadWelcome,leave:loadLeave,logging:loadLogging,automod:loadAutomod,antinuke:loadAntinuke,leveling:loadLeveling,tickets:loadTickets,joinrole:loadJoinRole,autoresponder:loadAutoResponder,moderation:loadModeration,permits:loadPermits,music:loadMusicPage};
  if(loads[p])loads[p]();
}
function toggleSlide(){n('slidePanel').classList.toggle('open');n('overlay').classList.toggle('open');}
function closeSlide(){n('slidePanel').classList.remove('open');n('overlay').classList.remove('open');}

// ── OVERVIEW ──
async function loadOverview(){
  const[d,mod]=await Promise.all([api('/api/guild/'+CG.id),api('/api/guild/'+CG.id+'/moderation')]);
  if(!d)return;
  sv('prefixInput',d.prefix||'!');
  // Stats
  const warn=mod?mod.warnings.length:0;const cases=mod?mod.cases.length:0;
  n('statsGrid').innerHTML=`
    <div class="sc"><div class="sc-lbl">Warnings</div><div class="sc-val">${warn}</div></div>
    <div class="sc"><div class="sc-lbl">Mod Cases</div><div class="sc-val">${cases}</div></div>
    <div class="sc"><div class="sc-lbl">Antinuke</div><div class="sc-val" style="color:${d.antinuke_enabled?'var(--green)':'var(--red2)'}">${d.antinuke_enabled?'ON':'OFF'}</div></div>
    <div class="sc"><div class="sc-lbl">Automod</div><div class="sc-val" style="color:${d.automod_enabled?'var(--green)':'var(--red2)'}">${d.automod_enabled?'ON':'OFF'}</div></div>
    <div class="sc"><div class="sc-lbl">Prefix</div><div class="sc-val" style="font-size:22px">${esc(d.prefix||'!')}</div></div>`;
  // Feature status
  const feats=[
    {name:'Antinuke',on:d.antinuke_enabled},
    {name:'Automod',on:d.automod_enabled},
    {name:'Welcome',on:!!(await api('/api/guild/'+CG.id+'/welcome').then(r=>r&&r.channel_id&&r.channel_id!=='0').catch(()=>false))},
    {name:'Leveling',on:!!(await api('/api/guild/'+CG.id+'/leveling').then(r=>r&&r.enabled&&bool(r.enabled)).catch(()=>false))},
    {name:'Tickets',on:!!(await api('/api/guild/'+CG.id+'/tickets').then(r=>r&&r.category_id&&r.category_id!=='0').catch(()=>false))},
    {name:'Join Roles',on:!!(await api('/api/guild/'+CG.id+'/joinrole').then(r=>r&&r.length>0).catch(()=>false))},
  ];
  n('featStatus').innerHTML=feats.map(f=>`<div class="fs-item"><div class="fs-name">${f.name}</div><div class="fs-dot ${f.on?'on':'off'}"></div></div>`).join('');
  // Recent warnings
  if(mod&&mod.warnings.length){
    n('ovWarnTable').innerHTML=mod.warnings.slice(0,5).map(w=>`<tr><td><code>${esc(w.user_id)}</code></td><td><code>${esc(w.mod_id)}</code></td><td>${esc(w.reason||'No reason')}</td><td style="color:var(--tx3);font-size:10px;font-family:'JetBrains Mono',monospace">${w.timestamp||''}</td></tr>`).join('');
  } else { n('ovWarnTable').innerHTML=noData(4,'no warnings'); }
  if(mod&&mod.cases.length){
    n('ovCasesTable').innerHTML=mod.cases.slice(0,5).map(c=>`<tr><td><span class="badge badge-eo">${esc(c.action||'')}</span></td><td><code>${esc(c.target_id)}</code></td><td><code>${esc(c.mod_id)}</code></td><td>${esc(c.reason||'No reason')}</td></tr>`).join('');
  } else { n('ovCasesTable').innerHTML=noData(4,'no cases'); }
}
async function savePrefix(){const p=gv('prefixInput');if(!p)return toast('Enter a prefix','error');const ok=await api('/api/guild/'+CG.id+'/prefix',{prefix:p},'POST');if(ok)toast('Prefix saved!','success');}

// ── WELCOME (fixed embed handling) ──
async function loadWelcome(){
  const d=await api('/api/guild/'+CG.id+'/welcome');if(!d)return;
  sv('wc_ch',d.channel_id&&d.channel_id!=='0'?d.channel_id:'');
  sv('wc_msg',d.message||'');
  // embed can be 0/1 integer or '0'/'1' string from DB
  n('wc_emb').value=(Number(d.embed)===1)?'1':'0';
  sc('wc_dm',d.dm_welcome);
  sv('wc_dmmsg',d.dm_message||'');
}
async function saveWelcome(){
  const payload={
    channel_id:gv('wc_ch')||'0',
    message:gv('wc_msg')||'Welcome {user}!',
    embed:n('wc_emb').value==='1'?1:0,
    dm_welcome:gc('wc_dm')?1:0,
    dm_message:gv('wc_dmmsg')||''
  };
  const ok=await api('/api/guild/'+CG.id+'/welcome',payload,'POST');
  if(ok)toast('Welcome saved!','success');
}

// ── LEAVE ──
async function loadLeave(){const d=await api('/api/guild/'+CG.id+'/leave');if(!d)return;sv('lv_ch',d.channel_id&&d.channel_id!=='0'?d.channel_id:'');sv('lv_msg',d.message||'');n('lv_emb').value=(Number(d.embed)===1)?'1':'0';}
async function saveLeave(){const ok=await api('/api/guild/'+CG.id+'/leave',{channel_id:gv('lv_ch')||'0',message:gv('lv_msg')||'{username} left.',embed:n('lv_emb').value==='1'?1:0},'POST');if(ok)toast('Leave saved!','success');}

// ── LOGGING ──
async function loadLogging(){const d=await api('/api/guild/'+CG.id+'/logging');if(!d)return;sv('lg_mod',d.mod_log&&d.mod_log!=='0'?d.mod_log:'');sv('lg_msg',d.message_log&&d.message_log!=='0'?d.message_log:'');sv('lg_join',d.join_log&&d.join_log!=='0'?d.join_log:'');sv('lg_member',d.member_log&&d.member_log!=='0'?d.member_log:'');sv('lg_voice',d.voice_log&&d.voice_log!=='0'?d.voice_log:'');sv('lg_roles',d.roles_log&&d.roles_log!=='0'?d.roles_log:'');sv('lg_am',d.automod_log&&d.automod_log!=='0'?d.automod_log:'');sv('lg_an',d.antinuke_log&&d.antinuke_log!=='0'?d.antinuke_log:'');sv('lg_guild',d.guild_log&&d.guild_log!=='0'?d.guild_log:'');sv('lg_security',d.security_log&&d.security_log!=='0'?d.security_log:'');sv('lg_ticket',d.ticket_log&&d.ticket_log!=='0'?d.ticket_log:'');sv('lg_bot',d.bot_log&&d.bot_log!=='0'?d.bot_log:'');}
async function saveLogging(){const ok=await api('/api/guild/'+CG.id+'/logging',{mod_log:gv('lg_mod')||'0',message_log:gv('lg_msg')||'0',join_log:gv('lg_join')||'0',member_log:gv('lg_member')||'0',voice_log:gv('lg_voice')||'0',roles_log:gv('lg_roles')||'0',automod_log:gv('lg_am')||'0',antinuke_log:gv('lg_an')||'0',guild_log:gv('lg_guild')||'0',security_log:gv('lg_security')||'0',ticket_log:gv('lg_ticket')||'0',bot_log:gv('lg_bot')||'0'},'POST');if(ok)toast('Logging saved!','success');}

// ── AUTOMOD ──
async function loadAutomod(){const d=await api('/api/guild/'+CG.id+'/automod');if(!d)return;sc('am_en',d.enabled);sv('am_log',d.log_channel&&d.log_channel!=='0'?d.log_channel:'');sc('am_spam',d.anti_spam);sc('am_invite',d.anti_invite);sc('am_mention',d.anti_mention);sc('am_caps',d.anti_caps);sc('am_link',d.anti_link);sc('am_nsfw',d.anti_nsfw);sc('am_phish',d.anti_phishing);sc('am_zalgo',d.anti_zalgo);sc('am_alt',d.anti_alt);sc('am_words',d.anti_words);sc('am_sticker',d.anti_sticker);sc('am_emoji',d.anti_emoji);}
async function saveAutomod(){const ok=await api('/api/guild/'+CG.id+'/automod',{enabled:gc('am_en'),log_channel:gv('am_log')||'0',anti_spam:gc('am_spam'),anti_invite:gc('am_invite'),anti_mention:gc('am_mention'),anti_caps:gc('am_caps'),anti_link:gc('am_link'),anti_nsfw:gc('am_nsfw'),anti_phishing:gc('am_phish'),anti_zalgo:gc('am_zalgo'),anti_alt:gc('am_alt'),anti_words:gc('am_words'),anti_sticker:gc('am_sticker'),anti_emoji:gc('am_emoji')},'POST');if(ok)toast('Automod saved!','success');}

// ── ANTINUKE ──
async function loadAntinuke(){const d=await api('/api/guild/'+CG.id+'/antinuke');if(!d)return;sc('an_en',d.enabled);sv('an_punish',d.punish||'ban');sv('an_log',d.log_channel&&d.log_channel!=='0'?d.log_channel:'');sc('an_panic',d.panic_mode);sc('an_ban',d.anti_ban);sc('an_kick',d.anti_kick);sc('an_bot',d.anti_bot);sc('an_ch_c',d.anti_channel_create);sc('an_ch_d',d.anti_channel_delete);sc('an_ch_u',d.anti_channel_update);sc('an_rl_c',d.anti_role_create);sc('an_rl_d',d.anti_role_delete);sc('an_rl_u',d.anti_role_update);sc('an_wh_c',d.anti_webhook_create);sc('an_wh_d',d.anti_webhook_delete);sc('an_everyone',d.anti_everyone);sc('an_guild',d.anti_guild_update);sc('an_prune',d.anti_prune);}
async function saveAntinuke(){const ok=await api('/api/guild/'+CG.id+'/antinuke',{enabled:gc('an_en'),punish:gv('an_punish'),log_channel:gv('an_log')||'0',panic_mode:gc('an_panic'),anti_ban:gc('an_ban'),anti_kick:gc('an_kick'),anti_bot:gc('an_bot'),anti_channel_create:gc('an_ch_c'),anti_channel_delete:gc('an_ch_d'),anti_channel_update:gc('an_ch_u'),anti_role_create:gc('an_rl_c'),anti_role_delete:gc('an_rl_d'),anti_role_update:gc('an_rl_u'),anti_webhook_create:gc('an_wh_c'),anti_webhook_delete:gc('an_wh_d'),anti_everyone:gc('an_everyone'),anti_guild_update:gc('an_guild'),anti_prune:gc('an_prune')},'POST');if(ok)toast('Antinuke saved!','success');}

// ── LEVELING ──
async function loadLeveling(){const d=await api('/api/guild/'+CG.id+'/leveling');if(!d)return;sc('lev_en',d.enabled);sv('lev_ch',d.channel_id&&d.channel_id!=='0'?d.channel_id:'');sv('lev_xp',d.xp_per_msg||'');sv('lev_xpmin',d.xp_min||'');sv('lev_xpmax',d.xp_max||'');sv('lev_cd',d.xp_cooldown||'');sv('lev_msg',d.message||'');}
async function saveLeveling(){const ok=await api('/api/guild/'+CG.id+'/leveling',{enabled:gc('lev_en'),channel_id:gv('lev_ch')||'0',xp_per_msg:gv('lev_xp')||15,xp_min:gv('lev_xpmin')||15,xp_max:gv('lev_xpmax')||25,xp_cooldown:gv('lev_cd')||60,message:gv('lev_msg')||'{user} leveled up to level {level}!'},'POST');if(ok)toast('Leveling saved!','success');}

// ── TICKETS ──
async function loadTickets(){const d=await api('/api/guild/'+CG.id+'/tickets');if(!d)return;sv('tk_cat',d.category_id&&d.category_id!=='0'?d.category_id:'');sv('tk_log',d.log_channel&&d.log_channel!=='0'?d.log_channel:'');sv('tk_role',d.support_role&&d.support_role!=='0'?d.support_role:'');sv('tk_msg',d.ticket_message||'');sv('tk_trans',d.transcript_channel&&d.transcript_channel!=='0'?d.transcript_channel:'');}
async function saveTickets(){const ok=await api('/api/guild/'+CG.id+'/tickets',{category_id:gv('tk_cat')||'0',log_channel:gv('tk_log')||'0',support_role:gv('tk_role')||'0',ticket_message:gv('tk_msg')||'Support will assist you shortly.',transcript_channel:gv('tk_trans')||'0'},'POST');if(ok)toast('Tickets saved!','success');}

// ── JOIN ROLES ──
async function loadJoinRole(){
  const data=await api('/api/guild/'+CG.id+'/joinrole');
  if(!data){n('joinroleList').innerHTML='<div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:\'JetBrains Mono\',monospace">// unable to load</div>';return;}
  n('joinroleList').innerHTML=data.length?data.map(r=>`
    <div class="pm-row">
      <div class="pm-info">
        <span class="badge badge-eo">${r.bot_only?'BOTS':'ALL'}</span>
        <span style="font-size:12px;font-family:'JetBrains Mono',monospace">${esc(r.role_id)}</span>
      </div>
      <button class="btn-rm" onclick="removeJoinRole('${esc(r.role_id)}')">Remove</button>
    </div>`).join(''):`<div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:'JetBrains Mono',monospace">// no join roles set</div>`;
}
async function addJoinRole(){
  const role=gv('jr_role');if(!role)return toast('Enter a Role ID','error');
  const bot_only=n('jr_bot').value==='1';
  const ok=await api('/api/guild/'+CG.id+'/joinrole/add',{role_id:role,bot_only},'POST');
  if(ok){toast('Join role added!','success');sv('jr_role','');loadJoinRole();}
}
async function removeJoinRole(rid){
  const ok=await api('/api/guild/'+CG.id+'/joinrole/remove',{role_id:rid},'POST');
  if(ok){toast('Removed!','success');loadJoinRole();}
}

// ── AUTO-RESPONDER ──
async function loadAutoResponder(){
  const data=await api('/api/guild/'+CG.id+'/autoresponder');
  if(!data){n('arList').innerHTML='<div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:\'JetBrains Mono\',monospace">// unable to load</div>';return;}
  n('arList').innerHTML=data.length?`<table class="wt"><thead><tr><th>Trigger</th><th>Response</th></tr></thead><tbody>${
    data.map(r=>`<tr><td><code>${esc(r.trigger||r.keyword||'')}</code></td><td>${esc(r.response||r.reply||'')}</td></tr>`).join('')
  }</tbody></table>`:`<div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:'JetBrains Mono',monospace">// no auto-responses set — use /autoresponder add in Discord</div>`;
}

// ── MODERATION ──
async function loadModeration(){
  const data=await api('/api/guild/'+CG.id+'/moderation');if(!data)return;
  n('modStats').innerHTML=`<div class="sc"><div class="sc-lbl">Total Warnings</div><div class="sc-val">${data.warnings.length}</div></div><div class="sc"><div class="sc-lbl">Total Cases</div><div class="sc-val">${data.cases.length}</div></div>`;
  n('warnTable').innerHTML=data.warnings.length?data.warnings.map(w=>`<tr><td><code>${esc(w.user_id)}</code></td><td><code>${esc(w.mod_id)}</code></td><td>${esc(w.reason||'No reason')}</td><td style="color:var(--tx3);font-size:10px;font-family:'JetBrains Mono',monospace">${w.timestamp||''}</td></tr>`).join(''):noData(4,'no warnings found');
  n('casesTable').innerHTML=data.cases.length?data.cases.map(c=>`<tr><td><span class="badge badge-eo">${esc(c.action||'')}</span></td><td><code>${esc(c.target_id)}</code></td><td><code>${esc(c.mod_id)}</code></td><td>${esc(c.reason||'No reason')}</td></tr>`).join(''):noData(4,'no cases found');
}

// ── PERMITS ──
async function loadPermits(){
  const data=await api('/api/guild/'+CG.id+'/permits');if(!data)return;
  const lvlBadge={extraowner:'badge-eo',serveradmin:'badge-sa',trustuser:'badge-tu'};
  n('permsList').innerHTML=data.perms.length?data.perms.map(p=>`<div class="pm-row"><div class="pm-info"><span class="badge ${lvlBadge[p.perm_level]||'badge-eo'}">${esc(p.perm_level)}</span><span style="font-size:12px;font-family:'JetBrains Mono',monospace">${esc(p.target_id)}</span><span style="font-size:10px;color:var(--tx3)">${esc(p.target_type||'user')}</span></div><button class="btn-rm" onclick="removePermit('${esc(p.target_id)}')">Remove</button></div>`).join(''):`<div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:'JetBrains Mono',monospace">// no permissions set</div>`;
}
async function addPermit(){
  const id=gv('pm_id');if(!id)return toast('Enter a user/role ID','error');
  const ok=await api('/api/guild/'+CG.id+'/permits/add',{target_id:id,target_type:'user',perm_level:gv('pm_level')},'POST');
  if(ok){toast('Permission added!','success');sv('pm_id','');loadPermits();}
}
async function removePermit(tid){
  const ok=await api('/api/guild/'+CG.id+'/permits/remove',{target_id:tid},'POST');
  if(ok){toast('Removed!','success');loadPermits();}
}
init();
</script>
</body>
</html>
