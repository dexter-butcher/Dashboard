<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Sentrax — Dashboard</title><link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/><style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#09090f;--bg2:#0f1019;--bg3:#141520;--border:#1e2235;--ac:#7c6bff;--ac2:#5b52e0;--gr:#3dcf8e;--red:#ff4d6d;--tx:#e8eaf0;--tx2:#8890aa;--tx3:#4a5070}
body{font-family:'Syne',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px}
/* LANDING */
.lnav{display:flex;align-items:center;justify-content:space-between;padding:16px 28px;position:sticky;top:0;z-index:100;background:rgba(9,9,15,.85);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
.lnav-logo{font-size:18px;font-weight:800;background:linear-gradient(135deg,#fff 30%,#9d8fff);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.lnav-links{display:flex;align-items:center;gap:20px}
.lnav-link{color:var(--tx2);font-size:13px;font-weight:600;text-decoration:none;transition:color .15s}.lnav-link:hover{color:var(--tx)}
.lnav-btn{background:var(--ac);color:#fff;padding:8px 18px;border-radius:8px;font-size:13px;font-weight:700;text-decoration:none;transition:all .2s}.lnav-btn:hover{background:var(--ac2);transform:translateY(-1px)}
.hero{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 24px 50px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;width:700px;height:700px;background:radial-gradient(circle,rgba(124,107,255,.07),transparent 65%);top:-200px;left:50%;transform:translateX(-50%);pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(124,107,255,.1);border:1px solid rgba(124,107,255,.25);border-radius:99px;padding:5px 14px;font-size:11px;font-weight:700;color:#9d8fff;font-family:'DM Mono',monospace;letter-spacing:.5px;margin-bottom:22px}
.hero-badge::before{content:'';width:6px;height:6px;background:var(--gr);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero-title{font-size:clamp(36px,8vw,68px);font-weight:800;line-height:1.05;letter-spacing:-2px;margin-bottom:14px}
.hero-title span{background:linear-gradient(135deg,#9d8fff,#7c6bff,#5b52e0);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-sub{color:var(--tx2);font-size:15px;max-width:480px;line-height:1.65;margin-bottom:32px}
.btn-pr{display:inline-flex;align-items:center;gap:8px;background:var(--ac);color:#fff;padding:12px 24px;border-radius:10px;font-family:'Syne',sans-serif;font-size:14px;font-weight:700;text-decoration:none;transition:all .2s}
.btn-pr:hover{background:var(--ac2);transform:translateY(-2px);box-shadow:0 8px 24px rgba(124,107,255,.35)}
.hero-stats{display:flex;justify-content:center;gap:36px;padding:36px 24px;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-top:50px;flex-wrap:wrap}
.hstat-val{font-size:26px;font-weight:800;background:linear-gradient(135deg,#fff,#9d8fff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center}
.hstat-lbl{font-size:10px;color:var(--tx3);font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:1px;margin-top:3px;text-align:center}
.feats{padding:60px 24px;max-width:960px;margin:0 auto}
.stag{display:inline-block;background:rgba(124,107,255,.1);border:1px solid rgba(124,107,255,.2);border-radius:6px;padding:4px 12px;font-size:11px;font-weight:700;color:#9d8fff;font-family:'DM Mono',monospace;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px}
.stitle{font-size:clamp(22px,4vw,34px);font-weight:800;letter-spacing:-1px;margin-bottom:6px}
.ssub{color:var(--tx2);font-size:13px;margin-bottom:36px}
.feat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px}
.fc{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:22px;transition:all .2s;position:relative;overflow:hidden}
.fc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--ac),var(--ac2));opacity:0;transition:.2s}
.fc:hover{border-color:rgba(124,107,255,.3);transform:translateY(-2px)}.fc:hover::before{opacity:1}
.fc-ico{font-size:22px;margin-bottom:12px}.fc-name{font-size:14px;font-weight:700;margin-bottom:5px}.fc-desc{font-size:11px;color:var(--tx2);line-height:1.6}
.lfooter{padding:24px 28px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.lfooter-logo{font-size:13px;font-weight:800;color:var(--tx2)}.lfooter-copy{font-size:10px;color:var(--tx3);font-family:'DM Mono',monospace}
/* APP */
#app{display:none}
.sidebar{position:fixed;left:0;top:0;width:210px;height:100vh;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;transition:transform .25s}
.sb-logo{padding:18px 16px 14px;font-size:17px;font-weight:800;background:linear-gradient(135deg,#fff,#9d8fff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;border-bottom:1px solid var(--border)}
.sb-server{padding:10px 12px;border-bottom:1px solid var(--border);cursor:pointer;display:flex;align-items:center;gap:8px;transition:.15s}.sb-server:hover{background:var(--bg3)}
.sb-server-icon{width:26px;height:26px;border-radius:50%;background:var(--bg3);flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800}
.sb-server-icon img{width:100%;height:100%;object-fit:cover}
.sb-server-name{font-size:12px;font-weight:700;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-server-change{font-size:10px;color:var(--tx3)}
.snav{padding:8px;flex:1;overflow-y:auto}
.snav-section{font-size:9px;font-weight:700;color:var(--tx3);font-family:'DM Mono',monospace;letter-spacing:1px;text-transform:uppercase;padding:10px 10px 4px}
.ni{display:flex;align-items:center;gap:9px;padding:9px 10px;border-radius:8px;cursor:pointer;color:var(--tx2);font-size:12px;font-weight:600;transition:all .15s;user-select:none}
.ni:hover{background:var(--bg3);color:var(--tx)}.ni.active{background:rgba(124,107,255,.12);color:#9d8fff}
.sb-user{padding:10px;border-top:1px solid var(--border);display:flex;align-items:center;gap:8px}
.sb-av{width:28px;height:28px;border-radius:50%;background:var(--bg3);flex-shrink:0}
.sb-uname{font-size:11px;font-weight:700;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sb-out{background:none;border:none;color:var(--tx3);cursor:pointer;font-size:15px;padding:4px;transition:color .15s}.sb-out:hover{color:var(--red)}
.main{margin-left:210px;min-height:100vh}
.topbar{height:52px;background:rgba(9,9,15,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:8px;position:sticky;top:0;z-index:50}
.tb-name{font-size:13px;font-weight:700;flex:1}.tb-page{color:var(--tx3);font-size:11px}
.hamburger{display:none;background:none;border:none;color:var(--tx);cursor:pointer;padding:6px;flex-direction:column;gap:4px;margin-left:auto}
.hamburger span{display:block;width:20px;height:2px;background:currentColor;border-radius:2px;transition:.2s}
.content{padding:20px;max-width:860px}
.page-section{display:none}
.page-title{font-size:22px;font-weight:800;letter-spacing:-.5px;margin-bottom:3px}
.page-sub{color:var(--tx2);font-size:11px;font-family:'DM Mono',monospace;margin-bottom:20px}
/* Guild picker */
#guild-picker{padding:20px;display:none}
.guilds-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px}
.gc{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px;cursor:pointer;transition:all .2s;text-align:center}
.gc:hover{border-color:rgba(124,107,255,.4);transform:translateY(-2px)}
.gc-icon{width:48px;height:48px;border-radius:50%;margin:0 auto 9px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;background:var(--bg3);overflow:hidden}
.gc-icon img{width:100%;height:100%;object-fit:cover}.gc-name{font-size:11px;font-weight:600}
/* Cards */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:14px}
.card-title{font-size:13px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.fg{display:flex;flex-direction:column;gap:4px}
label{font-size:9px;font-weight:700;color:var(--tx3);text-transform:uppercase;letter-spacing:.8px;font-family:'DM Mono',monospace}
input,select,textarea{background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--tx);font-family:'Syne',sans-serif;font-size:12px;padding:8px 10px;outline:none;transition:border-color .15s;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--ac)}
.tr{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--bg3)}
.tr:last-child{border-bottom:none}.tr-lbl{font-size:12px;font-weight:600}.tr-sub{font-size:10px;color:var(--tx3)}
.tog{position:relative;width:36px;height:20px;flex-shrink:0}
.tog input{opacity:0;width:0;height:0}
.tog-sl{position:absolute;cursor:pointer;inset:0;background:var(--bg3);border:1px solid var(--border);border-radius:10px;transition:.2s}
.tog-sl::before{content:'';position:absolute;width:12px;height:12px;left:3px;top:3px;background:var(--tx3);border-radius:50%;transition:.2s}
.tog input:checked+.tog-sl{background:rgba(124,107,255,.15);border-color:var(--ac)}
.tog input:checked+.tog-sl::before{transform:translateX(16px);background:var(--ac)}
.btn-save{background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff;border:none;border-radius:8px;padding:9px 18px;font-family:'Syne',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;margin-top:12px}
.btn-save:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(124,107,255,.35)}
.sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;margin-bottom:14px}
.sc{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:12px;position:relative;overflow:hidden}
.sc::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--ac),var(--ac2))}
.sc-lbl{font-size:9px;color:var(--tx3);font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:1px;margin-bottom:3px}
.sc-val{font-size:20px;font-weight:800}
.info{background:rgba(124,107,255,.06);border:1px solid rgba(124,107,255,.15);border-radius:8px;padding:9px 12px;font-size:11px;color:var(--tx2);margin-bottom:12px;font-family:'DM Mono',monospace}
.pg2{display:grid;grid-template-columns:1fr 1fr}
.pi{display:flex;align-items:center;justify-content:space-between;padding:8px 10px;border-bottom:1px solid var(--bg3)}
.pi:nth-child(odd){border-right:1px solid var(--bg3)}.pi-name{font-size:11px;font-weight:600}.pi-sub{font-size:9px;color:var(--tx3)}
.wt{width:100%;border-collapse:collapse;font-size:11px}
.wt th{text-align:left;padding:6px 8px;color:var(--tx3);font-size:9px;font-family:'DM Mono',monospace;text-transform:uppercase;border-bottom:1px solid var(--border)}
.wt td{padding:8px 8px;border-bottom:1px solid var(--bg3)}
.badge{display:inline-block;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:700}
.badge-eo{background:rgba(124,107,255,.15);color:#9d8fff}.badge-sa{background:rgba(61,207,142,.15);color:var(--gr)}.badge-tu{background:rgba(255,209,102,.15);color:#ffd166}
.pm-row{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-bottom:1px solid var(--bg3)}
.pm-row:last-child{border-bottom:none}
.pm-info{display:flex;align-items:center;gap:8px}
.btn-rm{background:rgba(255,77,109,.1);border:1px solid rgba(255,77,109,.2);color:var(--red);border-radius:6px;padding:3px 9px;font-size:10px;font-weight:700;cursor:pointer;font-family:'Syne',sans-serif;transition:all .15s}
.btn-rm:hover{background:rgba(255,77,109,.2)}
.add-row{display:grid;grid-template-columns:1fr 1fr auto;gap:8px;margin-top:12px;align-items:end}
/* Right slide panel */
.slide-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;opacity:0;pointer-events:none;transition:opacity .25s}
.slide-overlay.open{opacity:1;pointer-events:all}
.slide-panel{position:fixed;top:0;right:-280px;width:260px;height:100vh;background:var(--bg2);border-left:1px solid var(--border);z-index:201;transition:right .25s;display:flex;flex-direction:column;overflow-y:auto}
.slide-panel.open{right:0}
.sp-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px;border-bottom:1px solid var(--border)}
.sp-title{font-size:14px;font-weight:800}.sp-close{background:none;border:none;color:var(--tx2);cursor:pointer;font-size:18px}
.sp-user{display:flex;align-items:center;gap:10px;padding:14px 16px;border-bottom:1px solid var(--border)}
.sp-av{width:36px;height:36px;border-radius:50%;background:var(--bg3)}
.sp-uname{font-size:13px;font-weight:700}.sp-uid{font-size:10px;color:var(--tx3);font-family:'DM Mono',monospace}
.sp-links{padding:10px 8px;flex:1}
.sp-link{display:flex;align-items:center;gap:10px;padding:10px 10px;border-radius:8px;cursor:pointer;color:var(--tx2);font-size:13px;font-weight:600;transition:.15s;text-decoration:none}
.sp-link:hover{background:var(--bg3);color:var(--tx)}.sp-link.active{color:#9d8fff}
.sp-logout{margin:10px;padding:10px;background:rgba(255,77,109,.08);border:1px solid rgba(255,77,109,.2);border-radius:8px;color:var(--red);font-size:12px;font-weight:700;text-align:center;cursor:pointer;text-decoration:none;display:block;transition:.15s}
.sp-logout:hover{background:rgba(255,77,109,.15)}
#toast{position:fixed;bottom:18px;right:18px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:9px 14px;font-size:12px;font-weight:600;opacity:0;transform:translateY(8px);transition:all .25s;pointer-events:none;z-index:9999}
#toast.show{opacity:1;transform:translateY(0)}
#toast.success{border-color:rgba(61,207,142,.35);color:var(--gr)}
#toast.error{border-color:rgba(255,77,109,.35);color:var(--red)}
@media(max-width:700px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.mob-open{transform:translateX(0)}
  .main{margin-left:0}
  .hamburger{display:flex}
  .fr{grid-template-columns:1fr}
  .pg2{grid-template-columns:1fr}
  .add-row{grid-template-columns:1fr 1fr;grid-template-rows:auto auto}
  .add-row .btn-save{grid-column:1/-1}
  .lnav-links .lnav-link{display:none}
}
</style></head><body>
<div id="landing" style="display:flex;flex-direction:column;min-height:100vh">
  <nav class="lnav">
    <div class="lnav-logo">Sentrax&#8482;</div>
    <div class="lnav-links">
      <a class="lnav-link" href="#features">Features</a>
      <a class="lnav-link" href="/auth/login">Login</a>
      <a class="lnav-btn" href="/auth/login">Dashboard</a>
    </div>
  </nav>
  <div class="hero">
    <div class="hero-badge">&#9889; v2.0 &#8212; Now Live</div>
    <h1 class="hero-title">The Ultimate<br/><span>Discord Bot</span></h1>
    <p class="hero-sub">Military-grade moderation, antinuke protection, economy, music, leveling and 200+ commands &#8212; all in one bot.</p>
    <a class="btn-pr" href="/auth/login"><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>Open Dashboard</a>
    <div class="hero-stats">
      <div><div class="hstat-val">200+</div><div class="hstat-lbl">Commands</div></div>
      <div><div class="hstat-val">99.9%</div><div class="hstat-lbl">Uptime</div></div>
      <div><div class="hstat-val">15+</div><div class="hstat-lbl">Protections</div></div>
      <div><div class="hstat-val">Free</div><div class="hstat-lbl">Always</div></div>
    </div>
  </div>
  <div class="feats" id="features">
    <div class="stag">Features</div>
    <h2 class="stitle">Everything you need</h2>
    <p class="ssub">Built for serious server owners.</p>
    <div class="feat-grid">
      <div class="fc"><div class="fc-ico">&#9762;&#65039;</div><div class="fc-name">Antinuke</div><div class="fc-desc">15+ real-time protections against raids, mass bans, channel deletions and takeovers.</div></div>
      <div class="fc"><div class="fc-ico">&#128737;&#65039;</div><div class="fc-name">Automod</div><div class="fc-desc">Smart spam, invite, mention, caps, zalgo, phishing and bad word filtering.</div></div>
      <div class="fc"><div class="fc-ico">&#127925;</div><div class="fc-name">Music</div><div class="fc-desc">High quality Lavalink music with queue, filters, 24/7 mode and playlists.</div></div>
      <div class="fc"><div class="fc-ico">&#128200;</div><div class="fc-name">Leveling</div><div class="fc-desc">XP system with rank cards, leaderboards, level-up roles and custom messages.</div></div>
      <div class="fc"><div class="fc-ico">&#128176;</div><div class="fc-name">Economy</div><div class="fc-desc">Full economy with daily rewards, heists, fishing, mining and shops.</div></div>
      <div class="fc"><div class="fc-ico">&#9878;&#65039;</div><div class="fc-name">Moderation</div><div class="fc-desc">Ban, kick, warn, mute, purge, lockdown with full case logging.</div></div>
    </div>
  </div>
  <div style="flex:1"></div>
  <footer class="lfooter">
    <div class="lfooter-logo">Sentrax&#8482;</div>
    <div class="lfooter-copy">// &#169; 2026 Sentrax. All rights reserved.</div>
  </footer>
</div>

<div id="app">
  <aside class="sidebar" id="sidebar">
    <div class="sb-logo">Sentrax&#8482;</div>
    <div class="sb-server" id="serverBtn" onclick="showGuildPicker()">
      <div class="sb-server-icon" id="sbIcon"></div>
      <div class="sb-server-name" id="sbName">Select Server</div>
      <div class="sb-server-change">&#9660;</div>
    </div>
    <nav class="snav">
      <div class="snav-section">General</div>
      <div class="ni active" data-page="overview" onclick="sp('overview')">&#9889; Overview</div>
      <div class="snav-section">Config</div>
      <div class="ni" data-page="welcome" onclick="sp('welcome')">&#128075; Welcome</div>
      <div class="ni" data-page="leave" onclick="sp('leave')">&#128679; Leave</div>
      <div class="ni" data-page="logging" onclick="sp('logging')">&#128203; Logging</div>
      <div class="ni" data-page="automod" onclick="sp('automod')">&#128737;&#65039; Automod</div>
      <div class="ni" data-page="antinuke" onclick="sp('antinuke')">&#9762;&#65039; Antinuke</div>
      <div class="ni" data-page="leveling" onclick="sp('leveling')">&#128200; Leveling</div>
      <div class="ni" data-page="tickets" onclick="sp('tickets')">&#127915; Tickets</div>
      <div class="snav-section">Admin</div>
      <div class="ni" data-page="moderation" onclick="sp('moderation')">&#9878;&#65039; Moderation</div>
      <div class="ni" data-page="permits" onclick="sp('permits')">&#128274; Permits</div>
    </nav>
    <div class="sb-user"><img class="sb-av" id="sbAv" src=""/><div style="flex:1;min-width:0"><div class="sb-uname" id="sbUname">...</div></div><a href="/auth/logout" class="sb-out" title="Logout">&#9099;</a></div>
  </aside>

  <main class="main">
    <div class="topbar">
      <span class="tb-name" id="tbName">Select a server</span>
      <span id="tbSep" style="color:var(--border);margin:0 5px"></span>
      <span class="tb-page" id="tbPage"></span>
      <button class="hamburger" id="hamburger" onclick="toggleSlide()">
        <span></span><span></span><span></span>
      </button>
    </div>

    <div id="guild-picker">
      <div class="page-title">Your Servers</div>
      <div class="page-sub">// only servers with bot and your access</div>
      <div id="gp-empty" style="display:none;color:var(--tx3);font-size:13px;padding:20px 0">No servers found. Make sure the bot is in your server and you have extraowner permission.</div>
      <div class="guilds-grid" id="guildsGrid"></div>
    </div>

    <div class="content" id="dash-content" style="display:none">

      <div id="page-overview" class="page-section">
        <div class="page-title">Overview</div><div class="page-sub">// server at a glance</div>
        <div class="sg" id="statsGrid"></div>
        <div class="card"><div class="card-title">&#9881;&#65039; Bot Prefix</div>
          <div class="fr"><div class="fg"><label>Prefix</label><input type="text" id="prefixInput" maxlength="5" placeholder="!"/></div><div class="fg" style="justify-content:flex-end"><label style="visibility:hidden">x</label><button class="btn-save" style="margin-top:0;width:100%" onclick="savePrefix()">Save</button></div></div>
        </div>
      </div>

      <div id="page-welcome" class="page-section">
        <div class="page-title">Welcome</div><div class="page-sub">// member join messages</div>
        <div class="card"><div class="card-title">&#128075; Join Message</div>
          <div class="fr"><div class="fg"><label>Channel ID</label><input type="text" id="wc_ch" placeholder="Channel ID"/></div><div class="fg"><label>Style</label><select id="wc_emb"><option value="1">Embed</option><option value="0">Plain Text</option></select></div></div>
          <div class="fg" style="margin-bottom:10px"><label>Message ({user} {server} {count})</label><textarea id="wc_msg" rows="2" placeholder="Welcome {user} to {server}!"></textarea></div>
          <div class="tr"><div><div class="tr-lbl">Send DM on Join</div><div class="tr-sub">DM new members</div></div><label class="tog"><input type="checkbox" id="wc_dm"/><span class="tog-sl"></span></label></div>
          <div class="fg" style="margin-top:10px"><label>DM Message</label><textarea id="wc_dmmsg" rows="2" placeholder="Welcome to {server}!"></textarea></div>
          <button class="btn-save" onclick="saveWelcome()">&#128190; Save Welcome</button>
        </div>
      </div>

      <div id="page-leave" class="page-section">
        <div class="page-title">Leave</div><div class="page-sub">// member leave messages</div>
        <div class="card"><div class="card-title">&#128679; Leave Message</div>
          <div class="fr"><div class="fg"><label>Channel ID</label><input type="text" id="lv_ch" placeholder="Channel ID"/></div><div class="fg"><label>Style</label><select id="lv_emb"><option value="1">Embed</option><option value="0">Plain Text</option></select></div></div>
          <div class="fg" style="margin-bottom:10px"><label>Message ({username} {server})</label><textarea id="lv_msg" rows="2" placeholder="{username} has left {server}."></textarea></div>
          <button class="btn-save" onclick="saveLeave()">&#128190; Save Leave</button>
        </div>
      </div>

      <div id="page-logging" class="page-section">
        <div class="page-title">Logging</div><div class="page-sub">// log channel IDs (leave blank to disable)</div>
        <div class="card"><div class="card-title">&#128203; Log Channels</div>
          <div class="fr"><div class="fg"><label>Mod Log</label><input type="text" id="lg_mod" placeholder="Channel ID"/></div><div class="fg"><label>Message Log</label><input type="text" id="lg_msg" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Join Log</label><input type="text" id="lg_join" placeholder="Channel ID"/></div><div class="fg"><label>Member Log</label><input type="text" id="lg_member" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Voice Log</label><input type="text" id="lg_voice" placeholder="Channel ID"/></div><div class="fg"><label>Roles Log</label><input type="text" id="lg_roles" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Automod Log</label><input type="text" id="lg_am" placeholder="Channel ID"/></div><div class="fg"><label>Antinuke Log</label><input type="text" id="lg_an" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Guild Log</label><input type="text" id="lg_guild" placeholder="Channel ID"/></div><div class="fg"><label>Security Log</label><input type="text" id="lg_security" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Ticket Log</label><input type="text" id="lg_ticket" placeholder="Channel ID"/></div><div class="fg"><label>Bot Log</label><input type="text" id="lg_bot" placeholder="Channel ID"/></div></div>
          <button class="btn-save" onclick="saveLogging()">&#128190; Save Logging</button>
        </div>
      </div>

      <div id="page-automod" class="page-section">
        <div class="page-title">Automod</div><div class="page-sub">// automated moderation</div>
        <div class="card">
          <div class="card-hdr"><div class="card-title" style="margin-bottom:0">&#128737;&#65039; Automod Settings</div><label class="tog"><input type="checkbox" id="am_en"/><span class="tog-sl"></span></label></div>
          <div class="fg" style="margin-bottom:10px"><label>Log Channel</label><input type="text" id="am_log" placeholder="Channel ID"/></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Spam</div><div class="tr-sub">Detect message flooding</div></div><label class="tog"><input type="checkbox" id="am_spam"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Invite</div><div class="tr-sub">Block Discord invites</div></div><label class="tog"><input type="checkbox" id="am_invite"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Mention</div><div class="tr-sub">Limit mass mentions</div></div><label class="tog"><input type="checkbox" id="am_mention"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Caps</div><div class="tr-sub">Block excessive caps</div></div><label class="tog"><input type="checkbox" id="am_caps"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Link</div><div class="tr-sub">Block external links</div></div><label class="tog"><input type="checkbox" id="am_link"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-NSFW</div><div class="tr-sub">Block NSFW content</div></div><label class="tog"><input type="checkbox" id="am_nsfw"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Phishing</div><div class="tr-sub">Block scam links</div></div><label class="tog"><input type="checkbox" id="am_phish"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Zalgo</div><div class="tr-sub">Block zalgo text</div></div><label class="tog"><input type="checkbox" id="am_zalgo"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Alt</div><div class="tr-sub">Block new accounts</div></div><label class="tog"><input type="checkbox" id="am_alt"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Bad Words Filter</div><div class="tr-sub">Block custom words</div></div><label class="tog"><input type="checkbox" id="am_words"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Sticker</div><div class="tr-sub">Block stickers</div></div><label class="tog"><input type="checkbox" id="am_sticker"/><span class="tog-sl"></span></label></div>
          <div class="tr"><div><div class="tr-lbl">Anti-Emoji</div><div class="tr-sub">Limit emoji spam</div></div><label class="tog"><input type="checkbox" id="am_emoji"/><span class="tog-sl"></span></label></div>
          <button class="btn-save" onclick="saveAutomod()">&#128190; Save Automod</button>
        </div>
      </div>

      <div id="page-antinuke" class="page-section">
        <div class="page-title">Antinuke</div><div class="page-sub">// raid protection</div>
        <div class="card">
          <div class="card-hdr"><div class="card-title" style="margin-bottom:0">&#9762;&#65039; Antinuke Settings</div><label class="tog"><input type="checkbox" id="an_en"/><span class="tog-sl"></span></label></div>
          <div class="fr"><div class="fg"><label>Punishment</label><select id="an_punish"><option value="ban">Ban</option><option value="kick">Kick</option><option value="strip">Strip Roles</option></select></div><div class="fg"><label>Log Channel</label><input type="text" id="an_log" placeholder="Channel ID"/></div></div>
          <div class="tr"><div><div class="tr-lbl">Panic Mode</div><div class="tr-sub">Emergency lockdown</div></div><label class="tog"><input type="checkbox" id="an_panic"/><span class="tog-sl"></span></label></div>
          <div style="font-size:10px;color:var(--tx3);font-family:'DM Mono',monospace;padding:8px 0 4px;text-transform:uppercase;letter-spacing:1px">Protections</div>
          <div class="pg2">
            <div class="pi"><div><div class="pi-name">Anti-Ban</div><div class="pi-sub">Mass bans</div></div><label class="tog"><input type="checkbox" id="an_ban"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Kick</div><div class="pi-sub">Mass kicks</div></div><label class="tog"><input type="checkbox" id="an_kick"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Bot Add</div><div class="pi-sub">Unverified bots</div></div><label class="tog"><input type="checkbox" id="an_bot"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Channel Create</div><div class="pi-sub">Mass create</div></div><label class="tog"><input type="checkbox" id="an_ch_c"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Channel Delete</div><div class="pi-sub">Mass delete</div></div><label class="tog"><input type="checkbox" id="an_ch_d"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Channel Update</div><div class="pi-sub">Edits</div></div><label class="tog"><input type="checkbox" id="an_ch_u"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Role Create</div><div class="pi-sub">Mass create</div></div><label class="tog"><input type="checkbox" id="an_rl_c"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Role Delete</div><div class="pi-sub">Mass delete</div></div><label class="tog"><input type="checkbox" id="an_rl_d"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Role Update</div><div class="pi-sub">Perm edits</div></div><label class="tog"><input type="checkbox" id="an_rl_u"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Webhook Create</div><div class="pi-sub">Unauthorized</div></div><label class="tog"><input type="checkbox" id="an_wh_c"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Webhook Delete</div><div class="pi-sub">Deletion</div></div><label class="tog"><input type="checkbox" id="an_wh_d"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Everyone</div><div class="pi-sub">Ping abuse</div></div><label class="tog"><input type="checkbox" id="an_everyone"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Guild Update</div><div class="pi-sub">Server tampering</div></div><label class="tog"><input type="checkbox" id="an_guild"/><span class="tog-sl"></span></label></div>
            <div class="pi"><div><div class="pi-name">Anti-Prune</div><div class="pi-sub">Mass prune</div></div><label class="tog"><input type="checkbox" id="an_prune"/><span class="tog-sl"></span></label></div>
          </div>
          <button class="btn-save" onclick="saveAntinuke()">&#128190; Save Antinuke</button>
        </div>
      </div>

      <div id="page-leveling" class="page-section">
        <div class="page-title">Leveling</div><div class="page-sub">// xp &amp; rank system</div>
        <div class="card">
          <div class="card-hdr"><div class="card-title" style="margin-bottom:0">&#128200; Leveling Settings</div><label class="tog"><input type="checkbox" id="lev_en"/><span class="tog-sl"></span></label></div>
          <div class="fr"><div class="fg"><label>Level-Up Channel</label><input type="text" id="lev_ch" placeholder="Channel ID"/></div><div class="fg"><label>XP Per Message</label><input type="number" id="lev_xp" min="1" max="100" placeholder="15"/></div></div>
          <div class="fr"><div class="fg"><label>XP Min</label><input type="number" id="lev_xpmin" placeholder="15"/></div><div class="fg"><label>XP Max</label><input type="number" id="lev_xpmax" placeholder="25"/></div></div>
          <div class="fr"><div class="fg"><label>XP Cooldown (sec)</label><input type="number" id="lev_cd" placeholder="60"/></div></div>
          <div class="fg" style="margin-bottom:10px"><label>Level-Up Message ({user} {level})</label><input type="text" id="lev_msg" placeholder="{user} leveled up to level {level}!"/></div>
          <button class="btn-save" onclick="saveLeveling()">&#128190; Save Leveling</button>
        </div>
      </div>

      <div id="page-tickets" class="page-section">
        <div class="page-title">Tickets</div><div class="page-sub">// support ticket system</div>
        <div class="card"><div class="card-title">&#127915; Ticket Config</div>
          <div class="fr"><div class="fg"><label>Category ID</label><input type="text" id="tk_cat" placeholder="Category ID"/></div><div class="fg"><label>Log Channel</label><input type="text" id="tk_log" placeholder="Channel ID"/></div></div>
          <div class="fr"><div class="fg"><label>Support Role</label><input type="text" id="tk_role" placeholder="Role ID"/></div><div class="fg"><label>Transcript Channel</label><input type="text" id="tk_trans" placeholder="Channel ID"/></div></div>
          <div class="fg" style="margin-bottom:10px"><label>Welcome Message</label><textarea id="tk_msg" rows="2" placeholder="Welcome! Support will assist you shortly."></textarea></div>
          <button class="btn-save" onclick="saveTickets()">&#128190; Save Tickets</button>
        </div>
      </div>

      <div id="page-moderation" class="page-section">
        <div class="page-title">Moderation</div><div class="page-sub">// cases &amp; warnings</div>
        <div class="sg" id="modStats"></div>
        <div class="card"><div class="card-title">&#9888;&#65039; Recent Warnings</div><div style="overflow-x:auto"><table class="wt"><thead><tr><th>User</th><th>Mod</th><th>Reason</th><th>Date</th></tr></thead><tbody id="warnTable"></tbody></table></div></div>
        <div class="card"><div class="card-title">&#128210; Mod Cases</div><div style="overflow-x:auto"><table class="wt"><thead><tr><th>Action</th><th>Target</th><th>Mod</th><th>Reason</th></tr></thead><tbody id="casesTable"></tbody></table></div></div>
      </div>

      <div id="page-permits" class="page-section">
        <div class="page-title">Permits</div><div class="page-sub">// dashboard access control</div>
        <div class="info">Users with <strong>extraowner</strong> can access this dashboard. <strong>serveradmin</strong> and <strong>trustuser</strong> have limited bot access.</div>
        <div class="card"><div class="card-title">&#128274; Current Permissions</div>
          <div id="permsList"></div>
          <div class="add-row">
            <div class="fg"><label>User/Role ID</label><input type="text" id="pm_id" placeholder="Discord ID"/></div>
            <div class="fg"><label>Permission Level</label><select id="pm_level"><option value="extraowner">extraowner</option><option value="serveradmin">serveradmin</option><option value="trustuser">trustuser</option></select></div>
            <button class="btn-save" style="margin-top:0" onclick="addPermit()">+ Add</button>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Right slide panel -->
<div class="slide-overlay" id="overlay" onclick="closeSlide()"></div>
<div class="slide-panel" id="slidePanel">
  <div class="sp-hdr"><div class="sp-title">Sentrax&#8482;</div><button class="sp-close" onclick="closeSlide()">&#10005;</button></div>
  <div class="sp-user"><img class="sp-av" id="spAv" src=""/><div><div class="sp-uname" id="spUname">...</div><div class="sp-uid" id="spUid"></div></div></div>
  <div class="sp-links" id="spLinks">
    <div class="sp-link active" onclick="sp('overview');closeSlide()">&#9889; Overview</div>
    <div class="sp-link" onclick="sp('welcome');closeSlide()">&#128075; Welcome</div>
    <div class="sp-link" onclick="sp('leave');closeSlide()">&#128679; Leave</div>
    <div class="sp-link" onclick="sp('logging');closeSlide()">&#128203; Logging</div>
    <div class="sp-link" onclick="sp('automod');closeSlide()">&#128737;&#65039; Automod</div>
    <div class="sp-link" onclick="sp('antinuke');closeSlide()">&#9762;&#65039; Antinuke</div>
    <div class="sp-link" onclick="sp('leveling');closeSlide()">&#128200; Leveling</div>
    <div class="sp-link" onclick="sp('tickets');closeSlide()">&#127915; Tickets</div>
    <div class="sp-link" onclick="sp('moderation');closeSlide()">&#9878;&#65039; Moderation</div>
    <div class="sp-link" onclick="sp('permits');closeSlide()">&#128274; Permits</div>
  </div>
  <a href="/auth/logout" class="sp-logout">Logout</a>
</div>

<div id="toast"></div>
<script>
let CG=null;
function n(id){return document.getElementById(id);}
function bool(v){return !!Number(v);}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(msg,type){const e=n('toast');e.textContent=(type==='success'?'&#10003; ':'&#10007; ')+msg;e.className='show '+(type||'success');clearTimeout(window._tt);window._tt=setTimeout(()=>{e.className='';},3000);}
function getToken(){return localStorage.getItem('snx_token');}
async function api(url,body,method){try{const o={method:method||'GET',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(getToken()||'')}};if(body)o.body=JSON.stringify(body);const r=await fetch(url,o);const d=await r.json();if(!r.ok){toast(d.error||'Error','error');return null;}return d;}catch{toast('Network error','error');return null;}}
function gv(id){const e=n(id);return e?e.value.trim():'';}
function sv(id,v){const e=n(id);if(e)e.value=v!==null&&v!==undefined?String(v):'';}
function gc(id){const e=n(id);return e?e.checked:false;}
function sc(id,v){const e=n(id);if(e)e.checked=bool(v);}

async function init(){
  try{
    const r=await fetch('/api/me');
    if(!r.ok){showLanding();return;}
    const{user}=await r.json();
    showApp(user);loadGuilds();
  }catch{showLanding();}
}
function showLanding(){n('landing').style.display='flex';n('app').style.display='none';}
function showApp(u){
  n('landing').style.display='none';n('app').style.display='block';
  const av=u.avatar?`https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.png?size=64`:'https://cdn.discordapp.com/embed/avatars/0.png';
  n('sbAv').src=av;n('sbUname').textContent=u.username;
  n('spAv').src=av;n('spUname').textContent=u.username;n('spUid').textContent=u.id;
}
async function loadGuilds(){
  showGuildPicker();
  const guilds=await api('/api/guilds');
  const grid=n('guildsGrid');grid.innerHTML='';
  if(!guilds||guilds.length===0){n('gp-empty').style.display='block';return;}
  n('gp-empty').style.display='none';
  guilds.forEach(g=>{
    const c=document.createElement('div');c.className='gc';
    const ico=g.icon?`<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png?size=64" style="width:48px;height:48px;border-radius:50%;margin:0 auto 9px;display:block" alt=""/>`:`<div class="gc-icon">${g.name.charAt(0)}</div>`;
    c.innerHTML=ico+`<div class="gc-name">${esc(g.name)}</div>`;
    c.onclick=()=>selectGuild(g);grid.appendChild(c);
  });
}
function showGuildPicker(){
  n('guild-picker').style.display='block';n('dash-content').style.display='none';
  n('tbName').textContent='Select a server';n('tbSep').textContent='';n('tbPage').textContent='';
  n('sbName').textContent='Select Server';n('sbIcon').innerHTML='';CG=null;
}
function selectGuild(g){
  CG=g;n('guild-picker').style.display='none';n('dash-content').style.display='block';
  n('tbName').textContent=g.name;n('tbSep').textContent=' &#8250; ';
  n('sbName').textContent=g.name;
  if(g.icon)n('sbIcon').innerHTML=`<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png?size=32" style="width:26px;height:26px;border-radius:50%"/>`;
  else n('sbIcon').textContent=g.name.charAt(0);
  sp('overview');
}
function sp(p){
  if(!CG&&p!=='overview'){showGuildPicker();return;}
  document.querySelectorAll('.ni').forEach(e=>e.classList.toggle('active',e.dataset.page===p));
  document.querySelectorAll('.page-section').forEach(e=>e.style.display='none');
  const s=n('page-'+p);if(s)s.style.display='block';
  const L={overview:'Overview',welcome:'Welcome',leave:'Leave',logging:'Logging',automod:'Automod',antinuke:'Antinuke',leveling:'Leveling',tickets:'Tickets',moderation:'Moderation',permits:'Permits'};
  n('tbPage').textContent=L[p]||p;
  if(p==='overview')loadOverview();if(p==='welcome')loadWelcome();if(p==='leave')loadLeave();
  if(p==='logging')loadLogging();if(p==='automod')loadAutomod();if(p==='antinuke')loadAntinuke();
  if(p==='leveling')loadLeveling();if(p==='tickets')loadTickets();
  if(p==='moderation')loadModeration();if(p==='permits')loadPermits();
}
// Slide panel
function toggleSlide(){const s=n('slidePanel');const o=n('overlay');s.classList.toggle('open');o.classList.toggle('open');}
function closeSlide(){n('slidePanel').classList.remove('open');n('overlay').classList.remove('open');}

// Overview
async function loadOverview(){
  const d=await api('/api/guild/'+CG.id);if(!d)return;
  sv('prefixInput',d.prefix||'!');
  n('statsGrid').innerHTML=`
    <div class="sc"><div class="sc-lbl">Warnings</div><div class="sc-val">${d.warnings}</div></div>
    <div class="sc"><div class="sc-lbl">Mod Cases</div><div class="sc-val">${d.modcases}</div></div>
    <div class="sc"><div class="sc-lbl">Antinuke</div><div class="sc-val" style="color:${d.antinuke_enabled?'var(--gr)':'var(--red)'}">${d.antinuke_enabled?'ON':'OFF'}</div></div>
    <div class="sc"><div class="sc-lbl">Automod</div><div class="sc-val" style="color:${d.automod_enabled?'var(--gr)':'var(--red)'}">${d.automod_enabled?'ON':'OFF'}</div></div>`;
}
async function savePrefix(){const p=gv('prefixInput');if(!p)return toast('Enter a prefix','error');const ok=await api('/api/guild/'+CG.id+'/prefix',{prefix:p},'POST');if(ok)toast('Prefix saved!','success');}

// Welcome
async function loadWelcome(){const d=await api('/api/guild/'+CG.id+'/welcome');if(!d)return;sv('wc_ch',d.channel_id);sv('wc_msg',d.message);sv('wc_emb',d.embed===1||d.embed==='1'?'1':'0');sc('wc_dm',d.dm_welcome);sv('wc_dmmsg',d.dm_message);}
async function saveWelcome(){const ok=await api('/api/guild/'+CG.id+'/welcome',{channel_id:gv('wc_ch'),message:gv('wc_msg'),embed:gv('wc_emb')==='1',dm_welcome:gc('wc_dm'),dm_message:gv('wc_dmmsg')},'POST');if(ok)toast('Welcome saved!','success');}

// Leave
async function loadLeave(){const d=await api('/api/guild/'+CG.id+'/leave');if(!d)return;sv('lv_ch',d.channel_id);sv('lv_msg',d.message);sv('lv_emb',d.embed===1||d.embed==='1'?'1':'0');}
async function saveLeave(){const ok=await api('/api/guild/'+CG.id+'/leave',{channel_id:gv('lv_ch'),message:gv('lv_msg'),embed:gv('lv_emb')==='1'},'POST');if(ok)toast('Leave saved!','success');}

// Logging
async function loadLogging(){const d=await api('/api/guild/'+CG.id+'/logging');if(!d)return;sv('lg_mod',d.mod_log);sv('lg_msg',d.message_log);sv('lg_join',d.join_log);sv('lg_member',d.member_log);sv('lg_voice',d.voice_log);sv('lg_roles',d.roles_log);sv('lg_am',d.automod_log);sv('lg_an',d.antinuke_log);sv('lg_guild',d.guild_log);sv('lg_security',d.security_log);sv('lg_ticket',d.ticket_log);sv('lg_bot',d.bot_log);}
async function saveLogging(){const ok=await api('/api/guild/'+CG.id+'/logging',{mod_log:gv('lg_mod'),message_log:gv('lg_msg'),join_log:gv('lg_join'),member_log:gv('lg_member'),voice_log:gv('lg_voice'),roles_log:gv('lg_roles'),automod_log:gv('lg_am'),antinuke_log:gv('lg_an'),guild_log:gv('lg_guild'),security_log:gv('lg_security'),ticket_log:gv('lg_ticket'),bot_log:gv('lg_bot')},'POST');if(ok)toast('Logging saved!','success');}

// Automod
async function loadAutomod(){const d=await api('/api/guild/'+CG.id+'/automod');if(!d)return;sc('am_en',d.enabled);sv('am_log',d.log_channel);sc('am_spam',d.anti_spam);sc('am_invite',d.anti_invite);sc('am_mention',d.anti_mention);sc('am_caps',d.anti_caps);sc('am_link',d.anti_link);sc('am_nsfw',d.anti_nsfw);sc('am_phish',d.anti_phishing);sc('am_zalgo',d.anti_zalgo);sc('am_alt',d.anti_alt);sc('am_words',d.anti_words);sc('am_sticker',d.anti_sticker);sc('am_emoji',d.anti_emoji);}
async function saveAutomod(){const ok=await api('/api/guild/'+CG.id+'/automod',{enabled:gc('am_en'),log_channel:gv('am_log'),anti_spam:gc('am_spam'),anti_invite:gc('am_invite'),anti_mention:gc('am_mention'),anti_caps:gc('am_caps'),anti_link:gc('am_link'),anti_nsfw:gc('am_nsfw'),anti_phishing:gc('am_phish'),anti_zalgo:gc('am_zalgo'),anti_alt:gc('am_alt'),anti_words:gc('am_words'),anti_sticker:gc('am_sticker'),anti_emoji:gc('am_emoji')},'POST');if(ok)toast('Automod saved!','success');}

// Antinuke
async function loadAntinuke(){const d=await api('/api/guild/'+CG.id+'/antinuke');if(!d)return;sc('an_en',d.enabled);sv('an_punish',d.punish||'ban');sv('an_log',d.log_channel);sc('an_panic',d.panic_mode);sc('an_ban',d.anti_ban);sc('an_kick',d.anti_kick);sc('an_bot',d.anti_bot);sc('an_ch_c',d.anti_channel_create);sc('an_ch_d',d.anti_channel_delete);sc('an_ch_u',d.anti_channel_update);sc('an_rl_c',d.anti_role_create);sc('an_rl_d',d.anti_role_delete);sc('an_rl_u',d.anti_role_update);sc('an_wh_c',d.anti_webhook_create);sc('an_wh_d',d.anti_webhook_delete);sc('an_everyone',d.anti_everyone);sc('an_guild',d.anti_guild_update);sc('an_prune',d.anti_prune);}
async function saveAntinuke(){const ok=await api('/api/guild/'+CG.id+'/antinuke',{enabled:gc('an_en'),punish:gv('an_punish'),log_channel:gv('an_log'),panic_mode:gc('an_panic'),anti_ban:gc('an_ban'),anti_kick:gc('an_kick'),anti_bot:gc('an_bot'),anti_channel_create:gc('an_ch_c'),anti_channel_delete:gc('an_ch_d'),anti_channel_update:gc('an_ch_u'),anti_role_create:gc('an_rl_c'),anti_role_delete:gc('an_rl_d'),anti_role_update:gc('an_rl_u'),anti_webhook_create:gc('an_wh_c'),anti_webhook_delete:gc('an_wh_d'),anti_everyone:gc('an_everyone'),anti_guild_update:gc('an_guild'),anti_prune:gc('an_prune')},'POST');if(ok)toast('Antinuke saved!','success');}

// Leveling
async function loadLeveling(){const d=await api('/api/guild/'+CG.id+'/leveling');if(!d)return;sc('lev_en',d.enabled);sv('lev_ch',d.channel_id||d.levelup_channel);sv('lev_xp',d.xp_per_msg);sv('lev_xpmin',d.xp_min);sv('lev_xpmax',d.xp_max);sv('lev_cd',d.xp_cooldown);sv('lev_msg',d.message);}
async function saveLeveling(){const ok=await api('/api/guild/'+CG.id+'/leveling',{enabled:gc('lev_en'),channel_id:gv('lev_ch'),xp_per_msg:gv('lev_xp'),xp_min:gv('lev_xpmin'),xp_max:gv('lev_xpmax'),xp_cooldown:gv('lev_cd'),message:gv('lev_msg')},'POST');if(ok)toast('Leveling saved!','success');}

// Tickets
async function loadTickets(){const d=await api('/api/guild/'+CG.id+'/tickets');if(!d)return;sv('tk_cat',d.category_id);sv('tk_log',d.log_channel);sv('tk_role',d.support_role);sv('tk_msg',d.ticket_message);sv('tk_trans',d.transcript_channel);}
async function saveTickets(){const ok=await api('/api/guild/'+CG.id+'/tickets',{category_id:gv('tk_cat'),log_channel:gv('tk_log'),support_role:gv('tk_role'),ticket_message:gv('tk_msg'),transcript_channel:gv('tk_trans')},'POST');if(ok)toast('Tickets saved!','success');}

// Moderation
async function loadModeration(){
  const data=await api('/api/guild/'+CG.id+'/moderation');if(!data)return;
  n('modStats').innerHTML=`<div class="sc"><div class="sc-lbl">Warnings</div><div class="sc-val">${data.warnings.length}</div></div><div class="sc"><div class="sc-lbl">Cases</div><div class="sc-val">${data.cases.length}</div></div>`;
  n('warnTable').innerHTML=data.warnings.length?data.warnings.map(w=>`<tr><td><code>${esc(w.user_id)}</code></td><td><code>${esc(w.mod_id)}</code></td><td>${esc(w.reason||'No reason')}</td><td style="color:var(--tx3);font-size:10px">${w.timestamp||''}</td></tr>`).join(''):`<tr><td colspan="4" style="color:var(--tx3);text-align:center;padding:14px">No warnings</td></tr>`;
  n('casesTable').innerHTML=data.cases.length?data.cases.map(c=>`<tr><td><span class="badge badge-eo">${esc(c.action||'')}</span></td><td><code>${esc(c.target_id)}</code></td><td><code>${esc(c.mod_id)}</code></td><td>${esc(c.reason||'No reason')}</td></tr>`).join(''):`<tr><td colspan="4" style="color:var(--tx3);text-align:center;padding:14px">No cases</td></tr>`;
}

// Permits
async function loadPermits(){
  const data=await api('/api/guild/'+CG.id+'/permits');if(!data)return;
  const lvlBadge={extraowner:'badge-eo',serveradmin:'badge-sa',trustuser:'badge-tu'};
  n('permsList').innerHTML=data.perms.length?data.perms.map(p=>`
    <div class="pm-row">
      <div class="pm-info">
        <span class="badge ${lvlBadge[p.perm_level]||'badge-eo'}">${esc(p.perm_level)}</span>
        <span style="font-size:11px;font-family:'DM Mono',monospace">${esc(p.target_id)}</span>
        <span style="font-size:10px;color:var(--tx3)">${esc(p.target_type||'user')}</span>
      </div>
      <button class="btn-rm" onclick="removePermit('${esc(p.target_id)}')">Remove</button>
    </div>`).join(''):`<div style="color:var(--tx3);font-size:12px;padding:10px 0">No permissions set.</div>`;
}
async function addPermit(){
  const id=gv('pm_id');const level=gv('pm_level');
  if(!id)return toast('Enter a user/role ID','error');
  const ok=await api('/api/guild/'+CG.id+'/permits/add',{target_id:id,target_type:'user',perm_level:level},'POST');
  if(ok){toast('Permission added!','success');sv('pm_id','');loadPermits();}
}
async function removePermit(tid){
  const ok=await api('/api/guild/'+CG.id+'/permits/remove',{target_id:tid},'POST');
  if(ok){toast('Removed!','success');loadPermits();}
}
init();
</script></body></html>
