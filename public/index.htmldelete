</div>
<div id="toast"></div>

<script>
let CG=null;
function n(id){return document.getElementById(id);}
function bool(v){return !!Number(v);}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(msg,type){const e=n('toast');e.textContent=(type==='success'?'✓ ':'✗ ')+msg;e.className='show '+(type||'success');clearTimeout(window._tt);window._tt=setTimeout(()=>{e.className='';},3000);}
function getToken(){return localStorage.getItem('snx_token');}
async function api(url,body,method){try{const o={method:method||'GET',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(getToken()||'')}};if(body)o.body=JSON.stringify(body);const r=await fetch(url,o);const d=await r.json();if(!r.ok){toast(d.error||'Error','error');return null;}return d;}catch{toast('Network error','error');return null;}}
function gv(id){const e=n(id);return e?e.value.trim():'';}
function sv(id,v){const e=n(id);if(e)e.value=v!==null&&v!==undefined?String(v):'';}
function gc(id){const e=n(id);return e?e.checked:false;}
function sc(id,v){const e=n(id);if(e)e.checked=bool(v);}
async function init(){
  // Read token from URL if present (set by OAuth callback)
  const params=new URLSearchParams(window.location.search);
  const urlToken=params.get('snx_token');
  if(urlToken){localStorage.setItem('snx_token',urlToken);window.history.replaceState({},'','/');} 
  // Handle logout
  if(params.get('logout')==='1'){localStorage.removeItem('snx_token');window.history.replaceState({},'','/');}
  if(!getToken()){showLanding();return;}
  try{const r=await fetch('/api/me',{headers:{'Authorization':'Bearer '+(getToken()||'')}});if(!r.ok){localStorage.removeItem('snx_token');showLanding();return;}const{user}=await r.json();showApp(user);loadGuilds();}catch{showLanding();}
}
function showLanding(){n('landing').style.display='flex';n('app').style.display='none';}
function showApp(u){
  n('landing').style.display='none';n('app').style.display='block';
  const av=u.avatar?`https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.png?size=64`:'https://cdn.discordapp.com/embed/avatars/0.png';
  n('sbAv').src=av;n('sbUname').textContent=u.username;n('spAv').src=av;n('spUname').textContent=u.username;n('spUid').textContent=u.id;
}
async function loadGuilds(){
  showGuildPicker();
  const guilds=await api('/api/guilds');const grid=n('guildsGrid');grid.innerHTML='';
  if(!guilds||guilds.length===0){n('gp-empty').style.display='block';return;}
  n('gp-empty').style.display='none';
  guilds.forEach(g=>{
    const c=document.createElement('div');c.className='gc';
    c.innerHTML=`<div class="gc-icon">${g.icon?`<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png?size=64" style="width:100%;height:100%;object-fit:cover" alt=""/>`:g.name.charAt(0)}</div><div class="gc-name">${esc(g.name)}</div>`;
    c.onclick=()=>selectGuild(g);grid.appendChild(c);
  });
}
function showGuildPicker(){
  n('guild-picker').style.display='block';n('dash-content').style.display='none';
  n('tbCrumb').innerHTML='<span>Sentrax</span> / Select a server';
  n('sbName').textContent='Select Server';n('sbIcon').innerHTML='';CG=null;
}
function selectGuild(g){
  CG=g;n('guild-picker').style.display='none';n('dash-content').style.display='block';
  n('tbCrumb').innerHTML=`<span>Sentrax</span> / ${esc(g.name)}`;n('sbName').textContent=g.name;
  n('sbIcon').innerHTML=g.icon?`<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png?size=32" style="width:28px;height:28px;border-radius:3px;object-fit:cover"/>`:g.name.charAt(0);
  sp('overview');
}
function sp(p){
  if(!CG){showGuildPicker();return;}
  document.querySelectorAll('.ni').forEach(e=>e.classList.toggle('active',e.dataset.page===p));
  document.querySelectorAll('.page-section').forEach(e=>e.style.display='none');
  const s=n('page-'+p);if(s)s.style.display='block';
  if(p==='overview')loadOverview();if(p==='welcome')loadWelcome();if(p==='leave')loadLeave();
  if(p==='logging')loadLogging();if(p==='automod')loadAutomod();if(p==='antinuke')loadAntinuke();
  if(p==='leveling')loadLeveling();if(p==='tickets')loadTickets();
  if(p==='moderation')loadModeration();if(p==='permits')loadPermits();
}
function toggleSlide(){n('slidePanel').classList.toggle('open');n('overlay').classList.toggle('open');}
function closeSlide(){n('slidePanel').classList.remove('open');n('overlay').classList.remove('open');}
async function loadOverview(){const d=await api('/api/guild/'+CG.id);if(!d)return;sv('prefixInput',d.prefix||'!');n('statsGrid').innerHTML=`<div class="sc"><div class="sc-lbl">Warnings</div><div class="sc-val">${d.warnings}</div></div><div class="sc"><div class="sc-lbl">Mod Cases</div><div class="sc-val">${d.modcases}</div></div><div class="sc"><div class="sc-lbl">Antinuke</div><div class="sc-val" style="color:${d.antinuke_enabled?'#3dcf8e':'var(--red2)'}">${d.antinuke_enabled?'ON':'OFF'}</div></div><div class="sc"><div class="sc-lbl">Automod</div><div class="sc-val" style="color:${d.automod_enabled?'#3dcf8e':'var(--red2)'}">${d.automod_enabled?'ON':'OFF'}</div></div>`;}
async function savePrefix(){const p=gv('prefixInput');if(!p)return toast('Enter a prefix','error');const ok=await api('/api/guild/'+CG.id+'/prefix',{prefix:p},'POST');if(ok)toast('Prefix saved!','success');}
async function loadWelcome(){const d=await api('/api/guild/'+CG.id+'/welcome');if(!d)return;sv('wc_ch',d.channel_id);sv('wc_msg',d.message);sv('wc_emb',d.embed===1||d.embed==='1'?'1':'0');sc('wc_dm',d.dm_welcome);sv('wc_dmmsg',d.dm_message);}
async function saveWelcome(){const ok=await api('/api/guild/'+CG.id+'/welcome',{channel_id:gv('wc_ch'),message:gv('wc_msg'),embed:gv('wc_emb')==='1',dm_welcome:gc('wc_dm'),dm_message:gv('wc_dmmsg')},'POST');if(ok)toast('Welcome saved!','success');}
async function loadLeave(){const d=await api('/api/guild/'+CG.id+'/leave');if(!d)return;sv('lv_ch',d.channel_id);sv('lv_msg',d.message);sv('lv_emb',d.embed===1||d.embed==='1'?'1':'0');}
async function saveLeave(){const ok=await api('/api/guild/'+CG.id+'/leave',{channel_id:gv('lv_ch'),message:gv('lv_msg'),embed:gv('lv_emb')==='1'},'POST');if(ok)toast('Leave saved!','success');}
async function loadLogging(){const d=await api('/api/guild/'+CG.id+'/logging');if(!d)return;sv('lg_mod',d.mod_log);sv('lg_msg',d.message_log);sv('lg_join',d.join_log);sv('lg_member',d.member_log);sv('lg_voice',d.voice_log);sv('lg_roles',d.roles_log);sv('lg_am',d.automod_log);sv('lg_an',d.antinuke_log);sv('lg_guild',d.guild_log);sv('lg_security',d.security_log);sv('lg_ticket',d.ticket_log);sv('lg_bot',d.bot_log);}
async function saveLogging(){const ok=await api('/api/guild/'+CG.id+'/logging',{mod_log:gv('lg_mod'),message_log:gv('lg_msg'),join_log:gv('lg_join'),member_log:gv('lg_member'),voice_log:gv('lg_voice'),roles_log:gv('lg_roles'),automod_log:gv('lg_am'),antinuke_log:gv('lg_an'),guild_log:gv('lg_guild'),security_log:gv('lg_security'),ticket_log:gv('lg_ticket'),bot_log:gv('lg_bot')},'POST');if(ok)toast('Logging saved!','success');}
async function loadAutomod(){const d=await api('/api/guild/'+CG.id+'/automod');if(!d)return;sc('am_en',d.enabled);sv('am_log',d.log_channel);sc('am_spam',d.anti_spam);sc('am_invite',d.anti_invite);sc('am_mention',d.anti_mention);sc('am_caps',d.anti_caps);sc('am_link',d.anti_link);sc('am_nsfw',d.anti_nsfw);sc('am_phish',d.anti_phishing);sc('am_zalgo',d.anti_zalgo);sc('am_alt',d.anti_alt);sc('am_words',d.anti_words);sc('am_sticker',d.anti_sticker);sc('am_emoji',d.anti_emoji);}
async function saveAutomod(){const ok=await api('/api/guild/'+CG.id+'/automod',{enabled:gc('am_en'),log_channel:gv('am_log'),anti_spam:gc('am_spam'),anti_invite:gc('am_invite'),anti_mention:gc('am_mention'),anti_caps:gc('am_caps'),anti_link:gc('am_link'),anti_nsfw:gc('am_nsfw'),anti_phishing:gc('am_phish'),anti_zalgo:gc('am_zalgo'),anti_alt:gc('am_alt'),anti_words:gc('am_words'),anti_sticker:gc('am_sticker'),anti_emoji:gc('am_emoji')},'POST');if(ok)toast('Automod saved!','success');}
async function loadAntinuke(){const d=await api('/api/guild/'+CG.id+'/antinuke');if(!d)return;sc('an_en',d.enabled);sv('an_punish',d.punish||'ban');sv('an_log',d.log_channel);sc('an_panic',d.panic_mode);sc('an_ban',d.anti_ban);sc('an_kick',d.anti_kick);sc('an_bot',d.anti_bot);sc('an_ch_c',d.anti_channel_create);sc('an_ch_d',d.anti_channel_delete);sc('an_ch_u',d.anti_channel_update);sc('an_rl_c',d.anti_role_create);sc('an_rl_d',d.anti_role_delete);sc('an_rl_u',d.anti_role_update);sc('an_wh_c',d.anti_webhook_create);sc('an_wh_d',d.anti_webhook_delete);sc('an_everyone',d.anti_everyone);sc('an_guild',d.anti_guild_update);sc('an_prune',d.anti_prune);}
async function saveAntinuke(){const ok=await api('/api/guild/'+CG.id+'/antinuke',{enabled:gc('an_en'),punish:gv('an_punish'),log_channel:gv('an_log'),panic_mode:gc('an_panic'),anti_ban:gc('an_ban'),anti_kick:gc('an_kick'),anti_bot:gc('an_bot'),anti_channel_create:gc('an_ch_c'),anti_channel_delete:gc('an_ch_d'),anti_channel_update:gc('an_ch_u'),anti_role_create:gc('an_rl_c'),anti_role_delete:gc('an_rl_d'),anti_role_update:gc('an_rl_u'),anti_webhook_create:gc('an_wh_c'),anti_webhook_delete:gc('an_wh_d'),anti_everyone:gc('an_everyone'),anti_guild_update:gc('an_guild'),anti_prune:gc('an_prune')},'POST');if(ok)toast('Antinuke saved!','success');}
async function loadLeveling(){const d=await api('/api/guild/'+CG.id+'/leveling');if(!d)return;sc('lev_en',d.enabled);sv('lev_ch',d.channel_id||d.levelup_channel);sv('lev_xp',d.xp_per_msg);sv('lev_xpmin',d.xp_min);sv('lev_xpmax',d.xp_max);sv('lev_cd',d.xp_cooldown);sv('lev_msg',d.message);}
async function saveLeveling(){const ok=await api('/api/guild/'+CG.id+'/leveling',{enabled:gc('lev_en'),channel_id:gv('lev_ch'),xp_per_msg:gv('lev_xp'),xp_min:gv('lev_xpmin'),xp_max:gv('lev_xpmax'),xp_cooldown:gv('lev_cd'),message:gv('lev_msg')},'POST');if(ok)toast('Leveling saved!','success');}
async function loadTickets(){const d=await api('/api/guild/'+CG.id+'/tickets');if(!d)return;sv('tk_cat',d.category_id);sv('tk_log',d.log_channel);sv('tk_role',d.support_role);sv('tk_msg',d.ticket_message);sv('tk_trans',d.transcript_channel);}
async function saveTickets(){const ok=await api('/api/guild/'+CG.id+'/tickets',{category_id:gv('tk_cat'),log_channel:gv('tk_log'),support_role:gv('tk_role'),ticket_message:gv('tk_msg'),transcript_channel:gv('tk_trans')},'POST');if(ok)toast('Tickets saved!','success');}
async function loadModeration(){const data=await api('/api/guild/'+CG.id+'/moderation');if(!data)return;n('modStats').innerHTML=`<div class="sc"><div class="sc-lbl">Warnings</div><div class="sc-val">${data.warnings.length}</div></div><div class="sc"><div class="sc-lbl">Cases</div><div class="sc-val">${data.cases.length}</div></div>`;n('warnTable').innerHTML=data.warnings.length?data.warnings.map(w=>`<tr><td><code>${esc(w.user_id)}</code></td><td><code>${esc(w.mod_id)}</code></td><td>${esc(w.reason||'No reason')}</td><td style="color:var(--tx3);font-size:10px;font-family:'JetBrains Mono',monospace">${w.timestamp||''}</td></tr>`).join(''):`<tr><td colspan="4" style="color:var(--tx3);text-align:center;padding:20px;font-family:'JetBrains Mono',monospace;font-size:11px">// no warnings found</td></tr>`;n('casesTable').innerHTML=data.cases.length?data.cases.map(c=>`<tr><td><span class="badge badge-eo">${esc(c.action||'')}</span></td><td><code>${esc(c.target_id)}</code></td><td><code>${esc(c.mod_id)}</code></td><td>${esc(c.reason||'No reason')}</td></tr>`).join(''):`<tr><td colspan="4" style="color:var(--tx3);text-align:center;padding:20px;font-family:'JetBrains Mono',monospace;font-size:11px">// no cases found</td></tr>`;}
async function loadPermits(){const data=await api('/api/guild/'+CG.id+'/permits');if(!data)return;const lvlBadge={extraowner:'badge-eo',serveradmin:'badge-sa',trustuser:'badge-tu'};n('permsList').innerHTML=data.perms.length?data.perms.map(p=>`<div class="pm-row"><div class="pm-info"><span class="badge ${lvlBadge[p.perm_level]||'badge-eo'}">${esc(p.perm_level)}</span><span style="font-size:12px;font-family:'JetBrains Mono',monospace">${esc(p.target_id)}</span><span style="font-size:10px;color:var(--tx3)">${esc(p.target_type||'user')}</span></div><button class="btn-rm" onclick="removePermit('${esc(p.target_id)}')">Remove</button></div>`).join(''):`<div style="color:var(--tx3);font-size:12px;padding:12px 0;font-family:'JetBrains Mono',monospace">// no permissions set</div>`;}
async function addPermit(){const id=gv('pm_id');const level=gv('pm_level');if(!id)return toast('Enter a user/role ID','error');const ok=await api('/api/guild/'+CG.id+'/permits/add',{target_id:id,target_type:'user',perm_level:level},'POST');if(ok){toast('Permission added!','success');sv('pm_id','');loadPermits();}}
async function removePermit(tid){const ok=await api('/api/guild/'+CG.id+'/permits/remove',{target_id:tid},'POST');if(ok){toast('Removed!','success');loadPermits();}}
init();
</script>
</body>
</html>
